@model RealEstateProject.Models.State

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add State";
    ViewData["ActivePage"] = "State";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border-color);
    }

    .page-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
        margin: 0;
    }

    .page-subtitle {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 4px 0 0 0;
    }

    .section-card {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 24px;
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-main);
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        display: block;
        width: 100%;
        padding: 10px 12px;
        font-size: 0.875rem;
        font-weight: 400;
        line-height: 1.5;
        color: var(--text-main);
        background-color: #fff;
        background-clip: padding-box;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        transition: border-color .15s ease-in-out,box-shadow .15s ease-in-out;
    }

    .form-control:focus {
        border-color: #2563eb;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.25);
    }

    .btn-primary-action {
        background: #2563eb;
        border: 1px solid #2563eb;
        color: #ffffff;
        padding: 8px 20px;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-primary-action:hover {
        background: #1d4ed8;
        border-color: #1d4ed8;
    }

    .btn-secondary-action {
        background: #ffffff;
        border: 1px solid var(--border-color);
        color: #0f172a;
        padding: 8px 20px;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: 0.2s;
    }

    .btn-secondary-action:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
    }
</style>

<div class="container-fluid p-0">
    <div class="page-header">
        <div>
            <h1 class="page-title">Add State</h1>
            <p class="page-subtitle">Create a new state or region.</p>
        </div>
    </div>

    <div class="section-card">
        <form method="post" asp-action="Create">
            <div class="form-group">
                <label class="form-label">State Name</label>
                <input asp-for="StateName" class="form-control" placeholder="e.g., Gujarat" required />
                <span asp-validation-for="StateName" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-flex gap-3 mt-4 pt-3 border-top">
                <button type="submit" class="btn-primary-action">Save State</button>
                <a href="/State/Index" class="btn-secondary-action">Cancel</a>
            </div>
        </form>
    </div>
</div>