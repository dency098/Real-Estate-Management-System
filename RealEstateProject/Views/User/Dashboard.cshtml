@model List<RealEstateProject.Models.Property>

@{
    Layout = null;
    ViewData["Title"] = "My Dashboard";
}
@using Microsoft.AspNetCore.Http

@{
    var fullName = Context.Session.GetString("FullName");

    var userImage = Context.Session.GetString("UserImage");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RealEstateProject</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>

        :root {
            --primary: #2563eb;
            --primary-soft: #eff6ff;
            --sidebar: #0f172a;
            --bg: #f5f7fb;
            --card: #ffffff;
            --text: #111827;
            --muted: #6b7280;
            --border: #e5e7eb;
            --success: #16a34a;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            font-family: Segoe UI, sans-serif;
            color: var(--text);
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        /* ===================================
           SIDEBAR
        =================================== */

        .sidebar {
            width: 240px;
            background: #0f172a;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            padding: 18px 14px;
            overflow-y: auto;
            z-index: 1000;
            transition: .3s;
        }

        /* BRAND */

        .brand-box {
            text-align: center;
            padding-bottom: 18px;
            margin-bottom: 18px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .brand-box img {
                width: 120px;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }

        /* USER */

        .user-mini {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 16px;
            background: rgba(255,255,255,.04);
            margin-bottom: 22px;
        }

            .user-mini img {
                width: 46px;
                height: 46px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,.15);
            }

            .user-mini h6 {
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                margin-bottom: 2px;
            }

            .user-mini p {
                color: #94a3b8;
                font-size: 11px;
                margin: 0;
            }

        /* NAVIGATION */

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .nav-links li {
                margin-bottom: 6px;
            }

                .nav-links li a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    color: #94a3b8;
                    text-decoration: none;
                    padding: 11px 14px;
                    border-radius: 14px;
                    font-size: 14px;
                    font-weight: 500;
                    transition: .25s;
                }

                    .nav-links li a i {
                        width: 18px;
                        font-size: 15px;
                    }

                    /* HOVER */

                    .nav-links li a:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                        transform: translateX(3px);
                    }

                /* ACTIVE */

                .nav-links li.active a {
                    background: #2563eb;
                    color: #fff;
                    box-shadow: 0 8px 20px rgba(37,99,235,.25);
                }

        /* LOGOUT */

        .logout-link {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .logout-link a {
                color: #f87171 !important;
            }

                .logout-link a:hover {
                    background: rgba(248,113,113,.12) !important;
                }

        /* MAIN CONTENT FIX */

        .main-content {
            margin-left: 240px;
            width: calc(100% - 240px);
            transition: .3s;
        }

        /* RESPONSIVE */

        @@media(max-width:992px) {

            .sidebar {
                width: 82px;
                padding: 16px 10px;
            }

            .brand-box img {
                width: 42px;
            }

            .user-mini {
                justify-content: center;
                padding: 10px;
            }

                .user-mini div {
                    display: none;
                }

            .nav-links li a {
                justify-content: center;
                padding: 12px;
            }

                .nav-links li a span {
                    display: none;
                }

            .main-content {
                margin-left: 82px;
                width: calc(100% - 82px);
            }
        }

        @@media(max-width:768px) {

            .sidebar {
                width: 72px;
            }

            .main-content {
                margin-left: 72px;
                width: calc(100% - 72px);
            }
        }

        /* =========================
                        MAIN
                ========================== */

        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 28px;
        }

        /* =========================
                        TOP BAR
                ========================== */

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .topbar h2 {
                font-size: 28px;
                font-weight: 600;
                margin-bottom: 4px;
            }

            .topbar p {
                color: var(--muted);
                font-size: 14px;
                margin: 0;
            }

        .add-btn {
            background: var(--primary);
            color: #fff;
            border: none;
            height: 42px;
            padding: 0 18px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            transition: 0.3s;
        }

            .add-btn:hover {
                background: #1d4ed8;
            }

        /* =========================
                        STATS
                ========================== */

        .stats-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: 0.3s;
            height: 100%;
        }

            .stats-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.04);
            }

        .stats-left h6 {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .stats-left h3 {
            font-size: 26px;
            margin: 0;
            font-weight: 600;
        }

        .stats-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .blue {
            background: #dbeafe;
            color: #2563eb;
        }

        .green {
            background: #dcfce7;
            color: #16a34a;
        }

        .orange {
            background: #fef3c7;
            color: #d97706;
        }

        /* =========================
                        TABLE CARD
                ========================== */

        .table-card {
            background: #fff;
            border-radius: 18px;
            border: 1px solid var(--border);
            margin-top: 24px;
            overflow: hidden;
        }

        .table-header {
            padding: 20px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

            .table-header h5 {
                margin: 0;
                font-size: 18px;
                font-weight: 600;
            }

            .table-header p {
                margin: 3px 0 0;
                color: var(--muted);
                font-size: 13px;
            }

        .view-btn {
            border: none;
            background: var(--primary-soft);
            color: var(--primary);
            height: 38px;
            padding: 0 14px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
        }

        /* =========================
                        TABLE
                ========================== */

        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }

            .custom-table thead th {
                background: #f8fafc;
                color: #6b7280;
                font-size: 12px;
                font-weight: 600;
                padding: 14px 20px;
                border-bottom: 1px solid var(--border);
            }

            .custom-table tbody td {
                padding: 18px 20px;
                border-bottom: 1px solid #f1f5f9;
                vertical-align: middle;
            }

        .property-box {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .property-box img {
                width: 72px;
                height: 58px;
                border-radius: 10px;
                object-fit: cover;
            }

            .property-box h6 {
                margin-bottom: 4px;
                font-size: 15px;
                font-weight: 600;
            }

            .property-box span {
                font-size: 13px;
                color: var(--muted);
            }

        /* =========================
                        STATUS
                ========================== */

        .status-badge {
            padding: 7px 12px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
        }

        .approved {
            background: #dcfce7;
            color: #166534;
        }

        .pending {
            background: #fef3c7;
            color: #92400e;
        }

        .rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .price {
            font-size: 15px;
            font-weight: 600;
        }

        /* =========================
                        EMPTY
                ========================== */

        .empty-box {
            text-align: center;
            padding: 50px 20px;
        }

            .empty-box i {
                font-size: 40px;
                color: #cbd5e1;
                margin-bottom: 15px;
            }

            .empty-box h5 {
                font-size: 18px;
                margin-bottom: 6px;
            }

            .empty-box p {
                color: var(--muted);
                font-size: 14px;
            }

        /* =========================
                        RESPONSIVE
                ========================== */

        @@media(max-width:992px) {

            .sidebar-menu-dashboard {
                width: 90px;
                padding: 20px 10px;
            }

            .logo-box img {
                width: 42px;
            }

            .nav-menu-link {
                justify-content: center;
            }

                .nav-menu-link span {
                    display: none;
                }

            .main-content {
                margin-left: 90px;
                width: calc(100% - 90px);
            }
        }

        @@media(max-width:768px) {

            .main-content {
                padding: 15px;
            }

            .topbar {
                align-items: flex-start;
                flex-direction: column;
            }

            .custom-table {
                min-width: 650px;
            }
        }

    </style>

</head>

<body>

    <div class="dashboard-wrapper">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand-box">
                <img src="@Url.Content("~/images/logo/logo-footer@2x.png")" />
            </div>

            <div class="user-mini">

                <img src="@Url.Content(userImage ?? "~/images/profile/default.png")" />

                <h6>@fullName</h6>

            </div>

            <ul class="nav-links">

                <li>
                    <a asp-controller="User" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Dashboard">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="active">
                    <a asp-controller="User" asp-action="Profile">
                        <i class="fa-solid fa-user"></i>
                        <span>My Profile</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyProperties">
                        <i class="fa-solid fa-building"></i>
                        <span>My Properties</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyEnquiries">
                        <i class="fa-solid fa-handshake"></i>
                        <span>Property Deals</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Property">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add Property</span>
                    </a>
                </li>

                <li class="logout-link">
                    <a asp-controller="Account"
                       asp-action="Logout"
                       onclick="return confirm('Logout?');">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </li>

            </ul>

        </aside>

        <!-- MAIN -->
        <main class="main-content">

            <!-- TOP -->
            <div class="topbar">

                <div>
                    <h2>Dashboard</h2>
                    <p>Manage your property listings and approvals.</p>
                </div>

                <a asp-controller="User"
                   asp-action="Property"
                   class="add-btn d-flex align-items-center">

                    <i class="fa-solid fa-plus me-2"></i>
                    Add Property
                </a>

            </div>

            <!-- STATS -->
            <div class="row g-3">

                <div class="col-md-4">

                    <div class="stats-card">

                        <div class="stats-left">
                            <h6>Total Properties</h6>
                            <h3>@Model.Count()</h3>
                        </div>

                        <div class="stats-icon blue">
                            <i class="fa-solid fa-house"></i>
                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="stats-card">

                        <div class="stats-left">
                            <h6>Approved</h6>
                            <h3>@Model.Count(p => p.Status == "Approved")</h3>
                        </div>

                        <div class="stats-icon green">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="stats-card">

                        <div class="stats-left">
                            <h6>Pending Review</h6>
                            <h3>@Model.Count(p => p.Status == "Pending")</h3>
                        </div>

                        <div class="stats-icon orange">
                            <i class="fa-solid fa-clock"></i>
                        </div>

                    </div>

                </div>

            </div>

            <!-- TABLE -->
            <div class="table-card">

                <div class="table-header">

                    <div>
                        <h5>Recent Properties</h5>
                        <p>Your latest added properties.</p>
                    </div>

                    <a asp-controller="User"
                       asp-action="MyProperties"
                       class="view-btn d-flex align-items-center">

                        <i class="fa-solid fa-eye me-2"></i>
                        View All
                    </a>

                </div>

                <div class="table-responsive">

                    <table class="custom-table">

                        <thead>
                            <tr>
                                <th>Property</th>
                                <th>Status</th>
                                <th>Price</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.Take(5))
                            {
                                var img = item.ProperyImages.FirstOrDefault()?.ImagePath
                                ?? "~/images/default-property.jpg";

                                <tr>

                                    <td>

                                        <div class="property-box">

                                            <img src="@Url.Content(img)" />

                                            <div>
                                                <h6>@item.Title</h6>

                                                <span>
                                                    <i class="fa-solid fa-location-dot me-1"></i>
                                                    @(item.City?.CityName ?? "Location")
                                                </span>
                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        @if (item.Status == "Approved")
                                        {
                                            <span class="status-badge approved">
                                                Approved
                                            </span>
                                        }
                                        else if (item.Status == "Pending" || item.Status == "EditPending")
                                        {
                                            <span class="status-badge pending">
                                                Pending
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge rejected">
                                                @item.Status
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        <span class="price">
                                            ₹ @item.Price.ToString("N0")
                                        </span>
                                    </td>

                                </tr>
                            }

                            @if (!Model.Any())
                            {
                                <tr>

                                    <td colspan="3">

                                        <div class="empty-box">

                                            <i class="fa-solid fa-house-circle-xmark"></i>

                                            <h5>No Properties Found</h5>

                                            <p>
                                                You have not added any properties yet.
                                            </p>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>