@model RealEstateProject.Models.Property

@{
    Layout = null;
    ViewData["Title"] = "Add Property";

    var amenities = ViewBag.Amenities as List<RealEstateProject.Models.Amenity>;
}
@using Microsoft.AspNetCore.Http

@{
    var fullName = Context.Session.GetString("FullName");

    var userImage = Context.Session.GetString("UserImage");
}
<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - RealEstateProject</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>

        function previewImage(event){

            var wrapper = document.getElementById('previewWrapper');
            wrapper.innerHTML = '';
            wrapper.style.display = "flex";

            var files = event.target.files;

            if(files.length > 10){
                alert("Maximum 10 images allowed");
                event.target.value = "";
                return;
            }

            for(let i=0; i<files.length; i++){

                let file = files[i];

                // IMAGE TYPE VALIDATION
                let allowed = ["image/jpeg","image/png","image/webp"];

                if(!allowed.includes(file.type)){
                    alert("Only JPG, PNG, WEBP images allowed");
                    event.target.value = "";
                    wrapper.innerHTML = "";
                    return;
                }

                // IMAGE SIZE VALIDATION
                if(file.size > 5 * 1024 * 1024){
                    alert("Each image must be less than 5MB");
                    event.target.value = "";
                    wrapper.innerHTML = "";
                    return;
                }

                let reader = new FileReader();

                reader.onload = function(e){

                    let img = document.createElement('img');

                    img.src = e.target.result;

                    img.style.width = "100px";
                    img.style.height = "100px";
                    img.style.objectFit = "cover";
                    img.style.borderRadius = "10px";

                    wrapper.appendChild(img);
                }

                reader.readAsDataURL(file);
            }
        }

        document.getElementById("propertyForm").addEventListener("submit", function(e){

            let isValid = true;

            // AMENITIES VALIDATION
            let amenities = document.querySelectorAll("input[name='SelectedAmenities']:checked");

            if(amenities.length === 0){

                document.getElementById("amenityError").innerText =
                    "Select at least one amenity";

                isValid = false;
            }
            else{
                document.getElementById("amenityError").innerText = "";
            }

            // IMAGE VALIDATION
            let images = document.getElementById("imageFiles");

            if(images.files.length === 0){
                alert("Please upload at least one image");
                isValid = false;
            }

            // VIDEO VALIDATION
            let video = document.getElementById("videoFile");

            if(video.files.length > 0){

                let file = video.files[0];

                let allowedVideo =
                    ["video/mp4","video/webm","video/quicktime"];

                if(!allowedVideo.includes(file.type)){

                    alert("Only MP4, WEBM, MOV video allowed");

                    isValid = false;
                }

                // 50MB LIMIT
                if(file.size > 50 * 1024 * 1024){

                    alert("Video size must be less than 50MB");

                    isValid = false;
                }
            }

            // BOOTSTRAP VALIDATION
            if(!this.checkValidity()){

                this.classList.add("was-validated");

                isValid = false;
            }

            if(!isValid){
                e.preventDefault();
            }
        });

        $(document).ready(function(){

            $("#StateId").change(function(){

                var stateId = $(this).val();

                $("#CityId").empty();

                $("#CityId").append('<option value="">Loading...</option>');

                if(stateId){

                    $.ajax({

                        url:'/User/GetCitiesByState',
                        type:'GET',
                        data:{ stateId: stateId },

                        success:function(data){

                            $("#CityId").empty();

                            $("#CityId").append('<option value="">Select City</option>');

                            $.each(data,function(i,city){

                                $("#CityId").append(
                                    `<option value="${city.cityId}">
                                        ${city.cityName}
                                    </option>`
                                );
                            });
                        },

                        error:function(){

                            alert("Failed to load cities");
                        }
                    });
                }
                else{

                    $("#CityId").empty();

                    $("#CityId").append('<option value="">Select City</option>');
                }
            });
        });

    </script>
    <style>

        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-light: #eff6ff;
            --sidebar: #0f172a;
            --bg: #f1f5f9;
            --card: #ffffff;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e2e8f0;
            --success: #16a34a;
            --danger: #dc2626;
            --radius: 22px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            font-family: 'Inter',sans-serif;
            color: var(--text);
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        /* =========================================
                                    LAYOUT
                        ==========================================*/

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
        }

        /* ===================================
                   SIDEBAR
                =================================== */

        .sidebar {
            width: 240px;
            background: #0f172a;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            padding: 18px 14px;
            overflow-y: auto;
            z-index: 1000;
            transition: .3s;
        }

        /* BRAND */

        .brand-box {
            text-align: center;
            padding-bottom: 18px;
            margin-bottom: 18px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .brand-box img {
                width: 120px;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }

        /* USER */

        .user-mini {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 16px;
            background: rgba(255,255,255,.04);
            margin-bottom: 22px;
        }

            .user-mini img {
                width: 46px;
                height: 46px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,.15);
            }

            .user-mini h6 {
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                margin-bottom: 2px;
            }

            .user-mini p {
                color: #94a3b8;
                font-size: 11px;
                margin: 0;
            }

        /* NAVIGATION */

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .nav-links li {
                margin-bottom: 6px;
            }

                .nav-links li a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    color: #94a3b8;
                    text-decoration: none;
                    padding: 11px 14px;
                    border-radius: 14px;
                    font-size: 14px;
                    font-weight: 500;
                    transition: .25s;
                }

                    .nav-links li a i {
                        width: 18px;
                        font-size: 15px;
                    }

                    /* HOVER */

                    .nav-links li a:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                        transform: translateX(3px);
                    }

                /* ACTIVE */

                .nav-links li.active a {
                    background: #2563eb;
                    color: #fff;
                    box-shadow: 0 8px 20px rgba(37,99,235,.25);
                }

        /* LOGOUT */

        .logout-link {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .logout-link a {
                color: #f87171 !important;
            }

                .logout-link a:hover {
                    background: rgba(248,113,113,.12) !important;
                }

        /* MAIN CONTENT FIX */

        .main-content {
            margin-left: 240px;
            width: calc(100% - 240px);
            transition: .3s;
        }

        /* RESPONSIVE */

        @@media(max-width:992px) {

            .sidebar {
                width: 82px;
                padding: 16px 10px;
            }

            .brand-box img {
                width: 42px;
            }

            .user-mini {
                justify-content: center;
                padding: 10px;
            }

                .user-mini div {
                    display: none;
                }

            .nav-links li a {
                justify-content: center;
                padding: 12px;
            }

                .nav-links li a span {
                    display: none;
                }

            .main-content {
                margin-left: 82px;
                width: calc(100% - 82px);
            }
        }

        @@media(max-width:768px) {

            .sidebar {
                width: 72px;
            }

            .main-content {
                margin-left: 72px;
                width: calc(100% - 72px);
            }
        }

        /* =========================================
                                    MAIN
                        ==========================================*/

        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 35px;
        }

        /* =========================================
                                    TOP HEADER
                        ==========================================*/

        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 28px;
        }

            .top-header h2 {
                font-size: 34px;
                font-weight: 800;
                margin-bottom: 6px;
                letter-spacing: -1px;
            }

            .top-header p {
                margin: 0;
                color: var(--muted);
                font-size: 15px;
            }

        .header-badge {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 16px 22px;
            box-shadow: 0 10px 25px rgba(0,0,0,.04);
        }

            .header-badge span {
                display: block;
                color: var(--muted);
                font-size: 12px;
                margin-bottom: 4px;
            }

            .header-badge strong {
                font-size: 18px;
            }

        /* =========================================
                                    FORM CARD
                        ==========================================*/

        .form-card {
            background: var(--card);
            border-radius: 32px;
            padding: 35px;
            border: 1px solid var(--border);
            box-shadow: 0 15px 40px rgba(15,23,42,.04);
        }

        /* =========================================
                                    SECTION TITLE
                        ==========================================*/

        .section-block {
            margin-bottom: 35px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 22px;
        }

        .section-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 18px;
        }

        .section-title h5 {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

        .section-title p {
            margin: 2px 0 0;
            color: var(--muted);
            font-size: 13px;
        }

        /* =========================================
                                    INPUTS
                        ==========================================*/

        .form-label {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #334155;
        }

        .form-control,
        .form-select {
            height: 54px;
            border-radius: 16px;
            border: 1px solid var(--border);
            padding: 12px 16px;
            font-size: 14px;
            transition: .25s;
            box-shadow: none !important;
            background: #fff;
        }

        textarea.form-control {
            height: auto;
            min-height: 140px;
            resize: none;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(37,99,235,.08) !important;
        }

        /* =========================================
                                    GRID
                        ==========================================*/

        .grid-2 {
            display: grid;
            grid-template-columns: repeat(2,1fr);
            gap: 22px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 22px;
        }

        /* =========================================
                                    IMAGE UPLOAD
                        ==========================================*/

        .upload-wrapper {
            position: relative;
            border: 2px dashed #bfdbfe;
            border-radius: 28px;
            background: linear-gradient(to bottom right,#f8fbff,#eff6ff);
            overflow: hidden;
            padding: 35px;
        }

        .upload-content {
            text-align: center;
        }

        .upload-icon {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: #fff;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            color: var(--primary);
            box-shadow: 0 10px 25px rgba(37,99,235,.12);
            margin-bottom: 18px;
        }

        .upload-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .upload-subtitle {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 22px;
        }

        .custom-upload {
            position: relative;
            display: inline-block;
        }

            .custom-upload input {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
            }

        .upload-btn {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 14px 24px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 600;
        }

        .image-preview-wrapper {
            margin-top: 28px;
            display: none;
        }

        .image-preview {
            width: 100%;
            max-height: 360px;
            object-fit: cover;
            border-radius: 22px;
            border: 1px solid var(--border);
        }

        /* =========================================
                                    AMENITIES
                        ==========================================*/

        .amenities-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
            gap: 16px;
        }

        .amenity-item {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: .25s;
            cursor: pointer;
        }

            .amenity-item:hover {
                border-color: #93c5fd;
                transform: translateY(-2px);
                background: #f8fbff;
            }

            .amenity-item input {
                width: 18px;
                height: 18px;
                accent-color: var(--primary);
            }

            .amenity-item span {
                font-size: 14px;
                font-weight: 600;
            }

        /* =========================================
                                    SUBMIT
                        ==========================================*/

        .submit-btn {
            width: 100%;
            height: 60px;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg,var(--primary),#3b82f6);
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            margin-top: 40px;
            transition: .25s;
            box-shadow: 0 15px 30px rgba(37,99,235,.22);
        }

            .submit-btn:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg,var(--primary-dark),var(--primary));
            }

        .text-danger {
            font-size: 12px;
            margin-top: 6px;
        }

        /* =========================================
                                    RESPONSIVE
                        ==========================================*/

        @@media(max-width:1100px) {

            .sidebar {
                width: 90px;
                padding: 20px 10px;
            }

            .logo-box img {
                width: 42px;
            }

            .menu-link {
                justify-content: center;
            }

                .menu-link span {
                    display: none;
                }

            .main-content {
                margin-left: 90px;
                width: calc(100% - 90px);
            }
        }

        @@media(max-width:768px) {

            .grid-2,
            .grid-3 {
                grid-template-columns: 1fr;
            }

            .main-content {
                padding: 18px;
            }

            .form-card {
                padding: 22px;
                border-radius: 24px;
            }

            .top-header {
                flex-direction: column;
                align-items: flex-start;
            }

                .top-header h2 {
                    font-size: 28px;
                }

            .amenities-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

</head>

<body>

    <div class="dashboard-layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand-box">
                <img src="@Url.Content("~/images/logo/logo-footer@2x.png")" />
            </div>

            <div class="user-mini">

                <img src="@Url.Content(userImage ?? "~/images/profile/default.png")" />

                <h6>@fullName</h6>

            </div>

            <ul class="nav-links">

                <li>
                    <a asp-controller="User" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Dashboard">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="active">
                    <a asp-controller="User" asp-action="Profile">
                        <i class="fa-solid fa-user"></i>
                        <span>My Profile</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyProperties">
                        <i class="fa-solid fa-building"></i>
                        <span>My Properties</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyEnquiries">
                        <i class="fa-solid fa-handshake"></i>
                        <span>Property Deals</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Property">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add Property</span>
                    </a>
                </li>

                <li class="logout-link">
                    <a asp-controller="Account"
                       asp-action="Logout"
                       onclick="return confirm('Logout?');">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </li>

            </ul>

        </aside>

        <!-- MAIN -->

        <main class="main-content">

            <!-- HEADER -->

            <div class="top-header">

                <div>

                    <h2>Add New Property</h2>

                    <p>
                        Create a beautiful property listing with complete details and images.
                    </p>

                </div>

                <div class="header-badge">

                    <span>Listing Type</span>

                    <strong>Premium Listing</strong>

                </div>

            </div>

            <!-- FORM CARD -->

            <div class="form-card">

                <form asp-action="AddProperty"
                      method="post"
                      enctype="multipart/form-data"
                      id="propertyForm"
                      novalidate>

                    <!-- BASIC -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-circle-info"></i>
                            </div>

                            <div>
                                <h5>Basic Information</h5>
                                <p>Enter the main property details</p>
                            </div>

                        </div>

                        <div class="grid-2">

                            <div>
                                <label class="form-label">Property Title</label>

                                <input asp-for="Title"
                                       class="form-control"
                                       placeholder="Luxury Apartment in Ahmedabad"
                                       required
                                       minlength="5"
                                       maxlength="100" />

                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div>
                                <label class="form-label">Price</label>

                                <input asp-for="Price"
                                       type="number"
                                       class="form-control"
                                       placeholder="5000000"
                                       min="10000"
                                       max="999999999"
                                       required />
                            </div>

                            <div>
                                <label class="form-label">Property Type</label>

                                <select asp-for="PropertyType" class="form-select">

                                    <option value="">Select Type</option>
                                    <option>Sell</option>
                                    <option>Rent</option>

                                </select>

                                <span asp-validation-for="PropertyType" class="text-danger"></span>
                            </div>

                            <div>
                                <label class="form-label">Category</label>

                                <select asp-for="CategoryId"
                                        class="form-select"
                                        asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "CategoryName"))">
                                </select>

                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>

                        </div>

                    </div>

                    <!-- CONFIGURATION -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-sliders"></i>
                            </div>

                            <div>
                                <h5>Property Configuration</h5>
                                <p>Add rooms and furnishing details</p>
                            </div>

                        </div>

                        <div class="grid-3">

                            <div>
                                <label class="form-label">Area (Sqft)</label>

                                <input asp-for="AreaSqft"
                                       type="number"
                                       class="form-control"
                                       placeholder="1200"
                                       min="100"
                                       max="100000"
                                       required />
                            </div>

                            <div>
                                <label class="form-label">Bedrooms</label>

                                <input asp-for="Bedroom"
                                       type="number"
                                       class="form-control"
                                       placeholder="3"
                                       min="1"
                                       max="20"
                                       required />
                            </div>

                            <div>
                                <label class="form-label">Bathrooms</label>

                                <input asp-for="Bathrooms"
                                       type="number"
                                       class="form-control"
                                       placeholder="2"
                                       min="1"
                                       max="20"
                                       required />
                            </div>

                        </div>

                        <div class="mt-4">

                            <label class="form-label">Furnishing</label>

                            <select asp-for="Furnishing" class="form-select">

                                <option>Furnished</option>
                                <option>Semi-Furnished</option>
                                <option>Unfurnished</option>

                            </select>

                        </div>

                    </div>

                    <!-- LOCATION -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-location-dot"></i>
                            </div>

                            <div>
                                <h5>Location Details</h5>
                                <p>Select state and city information</p>
                            </div>

                        </div>

                        <div class="grid-3">

                            <div>

                                <label class="form-label">State</label>

                                <select id="StateId" class="form-select">

                                    <option value="">Select State</option>

                                    @if (ViewBag.States != null)
                                    {
                                        foreach (var state in ViewBag.States)
                                        {
                                            <option value="@state.StateId">
                                                @state.StateName
                                            </option>
                                        }
                                    }

                                </select>

                            </div>

                            <div>

                                <label class="form-label">City</label>

                                <select asp-for="CityId"
                                        id="CityId"
                                        class="form-select">

                                    <option value="">Select City</option>

                                </select>

                                <span asp-validation-for="CityId" class="text-danger"></span>

                            </div>

                            <div>

                                <label class="form-label">Pincode</label>

                                <input asp-for="Pincode"
                                       class="form-control"
                                       placeholder="380001"
                                       pattern="[0-9]{6}"
                                       maxlength="6"
                                       minlength="6"
                                       required />

                            </div>

                        </div>

                        <div class="mt-4">

                            <label class="form-label">Full Address</label>

                            <textarea asp-for="Address"
                                      class="form-control"
                                      placeholder="Enter full property address"
                                      required
                                      minlength="10"
                                      maxlength="500"></textarea>

                            <span asp-validation-for="Address" class="text-danger"></span>

                        </div>

                    </div>

                    <!-- DESCRIPTION -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-file-lines"></i>
                            </div>

                            <div>
                                <h5>Description</h5>
                                <p>Describe your property in detail</p>
                            </div>

                        </div>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  placeholder="Write a detailed property description..."
                                  required
                                  minlength="30"
                                  maxlength="2000"></textarea>

                        <span asp-validation-for="Description" class="text-danger"></span>

                    </div>
                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-video"></i>
                            </div>

                            <div>
                                <h5>Property Video</h5>
                                <p>Upload a video walkthrough</p>
                            </div>

                        </div>

                        <div class="upload-wrapper" style="padding: 20px;">

                            <div class="upload-content">
                                <div class="custom-upload" style="display:block;">
                                    <label class="form-label" style="text-align:left; display:block;">Select Video File (MP4, WEBM)</label>
                                    <input type="file"
                                           name="VideoFile"
                                           accept=".mp4,.webm,.mov"
                                           class="form-control"
                                           id="videoFile" />
                                </div>
                            </div>

                        </div>

                    </div>
                    <!-- IMAGE -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-image"></i>
                            </div>

                            <div>
                                <h5>Property Image</h5>
                                <p>Upload high quality property image</p>
                            </div>

                        </div>

                        <div class="upload-wrapper">

                            <div class="upload-content">

                                <div class="upload-icon">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                </div>

                                <div class="upload-title">
                                    Upload Property Image
                                </div>

                                <div class="upload-subtitle">
                                    JPG, PNG or WEBP supported
                                </div>

                                <div class="custom-upload">

                                    <button type="button" class="upload-btn">

                                        <i class="fa-solid fa-image me-2"></i>
                                        Choose Image

                                    </button>

                                    <input type="file"
                                           name="ImageFiles"
                                           accept=".jpg,.jpeg,.png,.webp"
                                           multiple
                                           id="imageFiles"
                                           onchange="previewImage(event)"
                                           required />

                                </div>

                                <div class="image-preview-wrapper" id="previewWrapper" style="display:none; gap:10px; flex-wrap:wrap; justify-content:center; margin-top:20px;">
                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- AMENITIES -->

                    <div class="section-block">

                        <div class="section-title">

                            <div class="section-icon">
                                <i class="fa-solid fa-star"></i>
                            </div>

                            <div>
                                <h5>Amenities</h5>
                                <p>Select available amenities and features</p>
                            </div>

                        </div>

                        <div class="amenities-grid">

                            @if (amenities != null)
                            {
                                foreach (var item in amenities)
                                {
                                    <label class="amenity-item">

                                        <input type="checkbox"
                                               name="SelectedAmenities"
                                               value="@item.AmenityId" />

                                        <span>@item.AmenityName</span>

                                    </label>
                                }
                            }

                        </div>

                        <span id="amenityError" class="text-danger"></span>

                    </div>

                    <!-- SUBMIT -->

                    <button type="submit" class="submit-btn">

                        <i class="fa-solid fa-paper-plane me-2"></i>

                        Publish Property

                    </button>

                </form>

            </div>

        </main>

    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>

        function previewImage(event){

            var wrapper = document.getElementById('previewWrapper');
            wrapper.innerHTML = '';
            wrapper.style.display = "flex";

            var files = event.target.files;

            for(let i=0; i<files.length; i++){
                let reader = new FileReader();
                reader.onload = function(e){
                    let img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.width = "100px";
                    img.style.height = "100px";
                    img.style.objectFit = "cover";
                    img.style.borderRadius = "10px";
                    wrapper.appendChild(img);
                }
                reader.readAsDataURL(files[i]);
            }
        }

        document.getElementById("propertyForm").addEventListener("submit", function(e){

            let amenities = document.querySelectorAll("input[name='SelectedAmenities']:checked");

            if(amenities.length === 0){

                document.getElementById("amenityError").innerText =
                    "Select at least one amenity";

                e.preventDefault();
            }
            else{

                document.getElementById("amenityError").innerText = "";
            }
        });

        $(document).ready(function(){

            $("#StateId").change(function(){

                var stateId = $(this).val();

                $("#CityId").empty();

                $("#CityId").append('<option value="">Loading...</option>');

                if(stateId){

                    $.ajax({

                        url:'/User/GetCitiesByState',
                        type:'GET',
                        data:{ stateId: stateId },

                        success:function(data){

                            $("#CityId").empty();

                            $("#CityId").append('<option value="">Select City</option>');

                            $.each(data,function(i,city){

                                $("#CityId").append(
                                    `<option value="${city.cityId}">
                                        ${city.cityName}
                                    </option>`
                                );
                            });
                        },

                        error:function(){

                            alert("Failed to load cities");
                        }
                    });
                }
                else{

                    $("#CityId").empty();

                    $("#CityId").append('<option value="">Select City</option>');
                }
            });
        });

    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>