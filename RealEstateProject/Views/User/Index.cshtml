<!-- PROPERTIES -->
<section class="flat-section flat-recommended">
    <div class="container">

        <!-- HEADER -->
        <div class="box-title text-center wow fadeInUp">
            <div class="text-subtitle text-primary">Featured Properties</div>
            <h3 class="mt-4 title">Recommended For You</h3>
        </div>

        <!-- CARDS -->
        <div class="row">

            @if (Model == null || !Model.Any())
            {
                <h4 class="text-danger text-center">No Properties Found</h4>
            }
            else
            {
                @foreach (var item in Model.Take(6))
                {
                    var image = item.ProperyImages?.FirstOrDefault()?.ImagePath;

                    if (string.IsNullOrEmpty(image))
                    {
                        image = "/images/default.jpg";
                    }

                    <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                        <div class="homelengo-box">

                            <!-- IMAGE -->
                            <div class="archive-top">
                                <a asp-controller="User"
                                   asp-action="ViewProperty"
                                   asp-route-id="@item.ProperyId"
                                   class="images-group">

                                    <div class="images-style">
                                        <img src="@Url.Content(image)"
                                             class="img-fluid"
                                             style="height:250px; object-fit:cover;" />
                                    </div>

                                    <!-- TAG -->
                                    <div class="top">
                                        <ul class="d-flex gap-6">
                                            <li class="flag-tag primary">Featured</li>

                                            @if (item.Status == "Sold")
                                            {
                                                <li class="flag-tag style-1 bg-danger">Sold</li>
                                            }
                                            else
                                            {
                                                <li class="flag-tag style-1">For Sale</li>
                                            }
                                        </ul>
                                    </div>

                                    <!-- ADDRESS -->
                                    <div class="bottom text-white">
                                        <i class="fa fa-map-marker-alt me-1"></i>
                                        @item.Address
                                    </div>
                                </a>
                            </div>

                            <!-- CONTENT -->
                            <div class="archive-bottom">
                                <div class="content-top">

                                    <h6 class="text-capitalize">
                                        <a asp-controller="User"
                                           asp-action="ViewProperty"
                                           asp-route-id="@item.ProperyId"
                                           class="link">
                                            @item.Title
                                        </a>
                                    </h6>

                                    <ul class="meta-list">
                                        <li class="item">
                                            <i class="icon icon-bed"></i>
                                            <span>Beds:</span>
                                            <span class="fw-6">@item.Bedroom</span>
                                        </li>

                                        <li class="item">
                                            <i class="icon icon-bath"></i>
                                            <span>Baths:</span>
                                            <span class="fw-6">@item.Bathrooms</span>
                                        </li>

                                        <li class="item">
                                            <i class="icon icon-sqft"></i>
                                            <span>Sqft:</span>
                                            <span class="fw-6">@item.AreaSqft</span>
                                        </li>
                                    </ul>

                                </div>

                                <!-- PRICE -->
                                <div class="content-bottom d-flex align-items-center justify-content-between">

                                    <!-- LEFT: USER INFO -->
                                    <div class="d-flex align-items-center gap-2">

                                        <div class="avatar avt-40 round">
                                            <img src="@(string.IsNullOrEmpty(item.User?.ProfileImage)
                                                                         ? Url.Content("~/images/profile/default.png")
                                                                         : Url.Content(item.User.ProfileImage))"
                                         class="profile-img" />
                                </div>

                                        <span class="text-muted fw-500">
                                            @item.User?.FullName
                                        </span>

                                    </div>

                                    <!-- RIGHT: PRICE -->
                                    <h6 class="price text-primary mb-0">
                                        ₹ @item.Price
                                    </h6>

                                </div>
                            </div>

                        </div>
                    </div>
                }
            }

        </div>
    </div>
</section>
