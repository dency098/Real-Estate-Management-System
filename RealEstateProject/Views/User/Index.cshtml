@model IEnumerable<RealEstateProject.Models.Property>

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>

    :root {
        --primary: #2563eb;
        --dark: #0f172a;
        --gray: #64748b;
        --light: #f8fafc;
        --border: #e2e8f0;
    }

    body {
        background: #f8fafc;
        overflow-x: hidden;
    }

    /* HERO */

    .business-hero {
        position: relative;
        min-height: 92vh;
        background: linear-gradient(rgba(15,23,42,.72), rgba(15,23,42,.82)), url('/images/banner/img-w-text1.jpg');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-badge {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 50px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.15);
        color: white;
        font-size: .85rem;
        margin-bottom: 25px;
        backdrop-filter: blur(10px);
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        color: white;
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .hero-desc {
        font-size: 1.1rem;
        color: rgba(255,255,255,.85);
        max-width: 750px;
        margin: auto auto 40px;
    }

    /* SEARCH */

    .business-search {
        background: white;
        padding: 18px;
        border-radius: 20px;
        box-shadow: 0 30px 60px rgba(0,0,0,.15);
        max-width: 1200px;
        margin: auto;
    }

    .search-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr 1fr 160px;
        gap: 15px;
    }

    .search-box {
        height: 64px;
        border: 1px solid var(--border);
        border-radius: 14px;
        display: flex;
        align-items: center;
        padding: 0 18px;
        background: white;
    }

        .search-box i {
            color: var(--primary);
            margin-right: 12px;
        }

        .search-box input,
        .search-box select {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-size: .95rem;
        }

    .search-btn {
        border: none;
        background: var(--primary);
        color: white;
        border-radius: 14px;
        font-weight: 700;
        transition: .3s;
    }

        .search-btn:hover {
            background: #1d4ed8;
        }

    /* STATS */

    .stats-section {
        margin-top: -60px;
        position: relative;
        z-index: 10;
    }

    .stats-wrapper {
        background: white;
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 20px 40px rgba(0,0,0,.08);
    }

    .stats-box h2 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: 8px;
    }

    .stats-box p {
        color: var(--gray);
        margin: 0;
    }

    /* SECTION */

    .section-padding {
        padding: 90px 0;
    }

    .section-subtitle {
        color: var(--primary);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: .08em;
        margin-bottom: 10px;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: 15px;
    }

    .section-desc {
        color: var(--gray);
        max-width: 700px;
        margin: auto;
    }

    /* PROPERTY CARD */

    .property-card {
        background: white;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid var(--border);
        transition: .3s;
        height: 100%;
    }

        .property-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 60px rgba(0,0,0,.08);
        }

    .property-image {
        position: relative;
    }

        .property-image img {
            width: 100%;
            height: 260px;
            object-fit: cover;
        }

    .property-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        display: flex;
        gap: 10px;
    }

    .badge-item {
        background: white;
        padding: 7px 14px;
        border-radius: 50px;
        font-size: .75rem;
        font-weight: 700;
    }

    .badge-sale {
        background: #2563eb;
        color: white;
    }

    .badge-sold {
        background: #dc2626;
        color: white;
    }

    .property-location {
        position: absolute;
        bottom: 16px;
        left: 18px;
        color: white;
        font-size: .9rem;
        background: rgba(0,0,0,.5);
        padding: 8px 14px;
        border-radius: 50px;
        backdrop-filter: blur(6px);
    }

    .property-content {
        padding: 22px;
    }

    .property-title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

        .property-title a {
            color: var(--dark);
            text-decoration: none;
        }

    .property-meta {
        display: flex;
        gap: 18px;
        margin-bottom: 20px;
        color: var(--gray);
        font-size: .9rem;
    }

    .property-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-top: 18px;
    }

    .owner-box {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .owner-box img {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            object-fit: cover;
        }

    .property-price {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--primary);
    }

    /* SERVICES */

    .service-card {
        background: white;
        border-radius: 22px;
        padding: 40px 30px;
        border: 1px solid var(--border);
        transition: .3s;
        height: 100%;
    }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0,0,0,.08);
        }

    .service-icon {
        width: 75px;
        height: 75px;
        border-radius: 20px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 25px;
    }

        .service-icon i {
            font-size: 30px;
            color: var(--primary);
        }

    .service-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 15px;
        color: var(--dark);
    }

    .service-desc {
        color: var(--gray);
        line-height: 1.7;
    }

    /* WHY US */

    .why-section {
        background: white;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0,0,0,.06);
    }

    .why-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .why-content {
        padding: 60px;
    }

    .benefit-item {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .benefit-icon {
        min-width: 60px;
        height: 60px;
        border-radius: 18px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .benefit-icon i {
            color: var(--primary);
            font-size: 22px;
        }

    .benefit-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--dark);
    }

    .benefit-desc {
        color: var(--gray);
        line-height: 1.7;
    }

    /* RESPONSIVE */

    @@media(max-width:991px) {

        .hero-title {
            font-size: 2.5rem;
        }

        .search-grid {
            grid-template-columns: 1fr;
        }

        .stats-wrapper {
            padding: 25px;
        }

        .why-content {
            padding: 35px;
        }

        .section-title {
            font-size: 2rem;
        }
    }

    /* ================= PROPERTY CARD ================= */

    .property-card {
        background: white;
        border-radius: 28px;
        overflow: hidden;
        transition: .35s;
        position: relative;
        border: 1px solid #edf2f7;
        box-shadow: 0 8px 30px rgba(15,23,42,.05);
    }

        .property-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 50px rgba(15,23,42,.12);
        }

    /* IMAGE */

    .property-image-wrapper {
        position: relative;
        overflow: hidden;
    }

    .property-image {
        width: 500px;
        height: 250px;
        object-fit: cover;
        transition: 0.6s;
    }

    .property-card:hover .property-image {
        transform: scale(1.08);
    }

    /* OVERLAY */

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.65), rgba(0,0,0,.05));
    }

    /* TOP TAG */

    .property-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 3;
        padding: 10px 18px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        backdrop-filter: blur(10px);
    }

    .badge-sale {
        background: rgba(37,99,235,.95);
        color: white;
    }

    .badge-sold {
        background: rgba(239,68,68,.95);
        color: white;
    }

    /* FAVORITE */

    .favorite-btn {
        position: absolute;
        top: 18px;
        right: 18px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,.18);
        backdrop-filter: blur(12px);
        color: white;
        border: none;
        z-index: 3;
        transition: .3s;
    }

        .favorite-btn:hover {
            background: white;
            color: #ef4444;
        }

    /* LOCATION */

    .property-location {
        position: absolute;
        bottom: 18px;
        left: 18px;
        z-index: 3;
        color: white;
        font-size: 14px;
        font-weight: 500;
    }

    /* CONTENT */

    .property-content {
        padding: 26px;
    }

    .property-title {
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 12px;
        color: #0f172a;
        line-height: 1.3;
    }

        .property-title a {
            color: inherit;
            text-decoration: none;
        }

            .property-title a:hover {
                color: #2563eb;
            }

    /* FEATURES */

    .property-features {
        display: flex;
        gap: 14px;
        margin-top: 20px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 14px;
        color: #334155;
        font-weight: 600;
    }

        .feature-item i {
            color: #2563eb;
        }

    /* BOTTOM */

    .property-footer {
        border-top: 1px solid #edf2f7;
        padding-top: 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .agent-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .agent-img {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #eff6ff;
    }

    .agent-name {
        font-size: 14px;
        font-weight: 700;
        color: #0f172a;
    }

    .agent-role {
        font-size: 12px;
        color: #64748b;
    }

    .property-price {
        text-align: right;
    }

        .property-price h4 {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
            color: #2563eb;
        }

        .property-price span {
            color: #64748b;
            font-size: 13px;
        }

</style>

<!-- HERO -->

<section class="business-hero">

    <div class="container">

        <div class="hero-content">

            <span class="hero-badge">
                India's Trusted Real Estate Platform
            </span>

            <h1 class="hero-title">
                Find Premium Properties <br />
                Across India
            </h1>

            <p class="hero-desc">
                Buy, sell and rent verified residential & commercial properties
                with confidence and transparency.
            </p>

            <!-- SEARCH -->

            <div class="business-search">

                <form method="GET" asp-controller="User" asp-action="Properties">

                    <div class="search-grid">

                        <div class="search-box">
                            <i class="fa-solid fa-location-dot"></i>

                            <input type="text"
                                   name="searchQuery"
                                   placeholder="Search by city, area or locality..." />
                        </div>

                        <div class="search-box">

                            <i class="fa-solid fa-building"></i>

                            <select name="propertyType">
                                <option value="">Property Type</option>
                                @if (ViewBag.PropertyTypes != null)
                                {
                                    foreach (var type in ViewBag.PropertyTypes as List<string>)
                                    {
                                        <option value="@type">@type</option>
                                    }
                                }
                            </select>

                        </div>

                        <div class="search-box">

                            <i class="fa-solid fa-indian-rupee-sign"></i>

                            <input type="number"
                                   name="minPrice"
                                   placeholder="Min Price (₹)"
                                   style="width: 100%; border: none; outline: none; background: transparent; font-size: .95rem;" />

                        </div>

                        <div class="search-box">

                            <i class="fa-solid fa-indian-rupee-sign"></i>

                            <input type="number"
                                   name="maxPrice"
                                   placeholder="Max Price (₹)"
                                   style="width: 100%; border: none; outline: none; background: transparent; font-size: .95rem;" />

                        </div>

                        <button type="submit" class="search-btn">

                            <i class="fa-solid fa-magnifying-glass"></i>
                            Search

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- STATS -->

<section class="stats-section">

    <div class="container">

        <div class="stats-wrapper">

            <div class="row text-center">

                <div class="col-md-3 col-6 mb-4 mb-md-0">

                    <div class="stats-box">
                        <h2>12K+</h2>
                        <p>Properties Listed</p>
                    </div>

                </div>

                <div class="col-md-3 col-6">

                    <div class="stats-box">
                        <h2>8K+</h2>
                        <p>Happy Clients</p>
                    </div>

                </div>

                <div class="col-md-3 col-6 mt-4 mt-md-0">

                    <div class="stats-box">
                        <h2>150+</h2>
                        <p>Cities Covered</p>
                    </div>

                </div>

                <div class="col-md-3 col-6 mt-4 mt-md-0">

                    <div class="stats-box">
                        <h2>24/7</h2>
                        <p>Customer Support</p>
                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- PROPERTIES -->
<section class="flat-section flat-recommended">
    <div class="container">

        <!-- HEADER -->
        <div class="box-title text-center wow fadeInUp">
            <div class="text-subtitle text-primary">Featured Properties</div>
            <h3 class="mt-4 title">Recommended For You</h3>
        </div>

        <!-- CARDS -->
        <div class="row">

            @if (Model == null || !Model.Any())
            {
                <h4 class="text-danger text-center">No Properties Found</h4>
            }
            else
                           @foreach (var item in Model.Take(6))
                {
                    var image = item.ProperyImages?.FirstOrDefault()?.ImagePath;

                    if (string.IsNullOrEmpty(image))
                    {
                        image = "/images/default.jpg";
                    }

                    <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                        <div class="property-card">

                            <!-- IMAGE -->
                            <div class="property-image-wrapper">

                                <a asp-controller="User"
                                   asp-action="ViewProperty"
                                   asp-route-id="@item.ProperyId">

                                    <img src="@Url.Content(image)"
                                         class="property-image" />

                                    <div class="image-overlay"></div>

                                </a>

                                <!-- BADGE -->
                                @if (item.Status == "Sold")
                                {
                                    <div class="property-badge badge-sold">
                                        Sold
                                    </div>
                                }
                                else if (item.PropertyType == "Sell")
                                {
                                    <div class="property-badge badge-sale">
                                        For Sale
                                    </div>
                                }
                                else if (item.PropertyType == "Rent")
                                {
                                    <div class="property-badge badge-sale">
                                        For Rent
                                    </div>
                                }
                                else
                                {
                                    <div>
                                        No found
                                    </div>



                                }


                                <!-- FAVORITE -->
                                @{
                                    var favList = ViewBag.FavoritePropertyIds as List<int>;
                                    var isFavorite = favList != null && favList.Contains(item.ProperyId);
                                }
                                <button class="favorite-btn" onclick="toggleFavorite(this, @item.ProperyId); return false;">
                                    <i class="@(isFavorite ? "fa-solid text-danger" : "fa-regular") fa-heart"></i>
                                </button>

                                <!-- LOCATION -->
                                <div class="property-location">
                                    <i class="fa-solid fa-location-dot me-1"></i>
                                    @item.Address
                                </div>

                            </div>

                            <!-- CONTENT -->
                            <div class="property-content">

                                <h3 class="property-title">

                                    <a asp-controller="User"
                                       asp-action="ViewProperty"
                                       asp-route-id="@item.ProperyId">

                                        @item.Title

                                    </a>

                                </h3>

                                <!-- FEATURES -->
                                <div class="property-features">

                                    <div class="feature-item">
                                        <i class="fa-solid fa-bed"></i>
                                        @item.Bedroom Beds
                                    </div>

                                    <div class="feature-item">
                                        <i class="fa-solid fa-bath"></i>
                                        @item.Bathrooms Baths
                                    </div>

                                    <div class="feature-item">
                                        <i class="fa-solid fa-ruler-combined"></i>
                                        @item.AreaSqft Sqft
                                    </div>

                                </div>

                                <!-- FOOTER -->
                                <div class="property-footer">

                                    <!-- AGENT -->
                                    <div class="agent-box">

                                        <img src="@(string.IsNullOrEmpty(item.User?.ProfileImage)
                                                                                     ? Url.Content("~/images/profile/default.png")
                                                                                     : Url.Content(item.User.ProfileImage))"
                                             class="agent-img" />

                                        <div>
                                            <div class="agent-name">
                                                @item.User?.FullName
                                            </div>

                                            <div class="agent-role">
                                                Property Agent
                                            </div>
                                        </div>

                                    </div>

                                    <!-- PRICE -->
                                    <div class="property-price">

                                        <h4>
                                            ₹ @item.Price
                                        </h4>

                                        <span>Starting Price</span>

                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>
                }     
            

        </div>
    </div>
</section>


<!-- SERVICES -->

