@{
    ViewData["Title"] = "Contact Us";
}

<!-- ================= HERO SECTION ================= -->
<section class="contact-hero position-relative overflow-hidden">
    <div class="hero-overlay"></div>

    <!-- Floating Shapes -->
    <div class="hero-shape shape-1"></div>
    <div class="hero-shape shape-2"></div>

    <div class="container position-relative z-2">
        <div class="row justify-content-center align-items-center text-center">
            <div class="col-lg-8">

                <span class="hero-badge">
                    <i class="fa-solid fa-headset"></i>
                    24/7 Customer Support
                </span>

                <h1 class="hero-title">
                    Let's Talk About Your
                    <span>Dream Property</span>
                </h1>

                <p class="hero-subtitle">
                    Whether you're buying, selling, or investing —
                    our expert team is here to guide you every step of the way.
                </p>

                <div class="hero-buttons">
                    <a href="#contactForm" class="btn btn-light btn-lg rounded-pill px-4">
                        Send Message
                    </a>

                    <a href="tel:+919999999999" class="btn btn-outline-light btn-lg rounded-pill px-4">
                        <i class="fa-solid fa-phone me-2"></i>Call Now
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- ================= CONTACT SECTION ================= -->
<section class="contact-section">
    <div class="container">

        <div class="row g-5">

            <!-- LEFT INFO -->
            <div class="col-lg-4">

                <div class="contact-info-card">

                    <div class="section-mini-title">
                        CONTACT INFO
                    </div>

                    <h2 class="contact-side-title">
                        We're Always Ready To Help You
                    </h2>

                    <p class="contact-side-text">
                        Connect with our real estate professionals for property
                        consultation, buying, selling, or investment support.
                    </p>

                    <!-- INFO ITEMS -->
                    <div class="contact-info-list">

                        <div class="contact-item">
                            <div class="contact-icon blue">
                                <i class="fa-solid fa-location-dot"></i>
                            </div>

                            <div>
                                <h6>Office Address</h6>
                                <p>Surat, Gujarat, India</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon green">
                                <i class="fa-solid fa-phone"></i>
                            </div>

                            <div>
                                <h6>Call Us</h6>
                                <p>+91 99999 99999</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon orange">
                                <i class="fa-solid fa-envelope"></i>
                            </div>

                            <div>
                                <h6>Email Address</h6>
                                <p>support@realestate.com</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon purple">
                                <i class="fa-solid fa-clock"></i>
                            </div>

                            <div>
                                <h6>Working Hours</h6>
                                <p>Mon - Sat : 9 AM - 7 PM</p>
                            </div>
                        </div>

                    </div>

                    <!-- SOCIAL -->
                    <div class="social-wrapper">
                        <h6 class="mb-3 fw-bold">Follow Us</h6>

                        <div class="social-links">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                        </div>
                    </div>

                </div>

            </div>

            <!-- RIGHT FORM -->
            <div class="col-lg-8">

                <div class="contact-form-card" id="contactForm">

                    <div class="section-mini-title">
                        SEND MESSAGE
                    </div>

                    <h2 class="form-title">
                        We'd Love To Hear From You
                    </h2>

                    <p class="form-subtitle">
                        Fill out the form below and our team will contact you shortly.
                    </p>

                    <form>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="modern-input">
                                    <label>Full Name</label>
                                    <input type="text" placeholder="Enter your full name">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="modern-input">
                                    <label>Email Address</label>
                                    <input type="email" placeholder="Enter your email">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="modern-input">
                                    <label>Phone Number</label>
                                    <input type="text" placeholder="Enter phone number">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="modern-input">
                                    <label>Subject</label>
                                    <input type="text" placeholder="Enter subject">
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="modern-input">
                                    <label>Your Message</label>
                                    <textarea rows="6" placeholder="Write your message here..."></textarea>
                                </div>
                            </div>

                            <div class="col-12 mt-2">
                                <button type="submit" class="submit-btn">
                                    Send Message
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</section>

<!-- ================= MAP SECTION ================= -->
<section class="map-wrapper">

    <div class="map-top-content text-center">
        <span class="section-mini-title">
            OUR LOCATION
        </span>

        <h2 class="map-title">
            Visit Our Office
        </h2>

        <p class="map-subtitle">
            Meet our experts and explore premium property opportunities.
        </p>
    </div>

    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.8163134949195!2d72.83106297503279!3d21.199049682542984!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04fdf8f4e1c75%3A0x9f89d1b9e2f2d2d!2sSurat%2C%20Gujarat!5e0!3m2!1sen!2sin!4v1715168200000!5m2!1sen!2sin"
            width="100%"
            height="500"
            style="border:0;"
            allowfullscreen=""
            loading="lazy">
    </iframe>

</section>

<style>

    :root {
        --primary: #1565ff;
        --primary-dark: #0f4ed6;
        --dark: #0f172a;
        --text: #64748b;
        --light-bg: #f8fbff;
        --border: #e5edf8;
    }

    body {
        background: #fff;
    }

    /* ================= HERO ================= */

    .contact-hero {
        position: relative;
        padding: 170px 0 120px;
        background: linear-gradient(135deg, rgba(8,15,40,0.92), rgba(21,101,255,0.85)), url('/images/banner/banner.jpg');
        background-size: cover;
        background-position: center;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        backdrop-filter: blur(2px);
    }

    .hero-shape {
        position: absolute;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
    }

    .shape-1 {
        width: 260px;
        height: 260px;
        top: -50px;
        right: -50px;
    }

    .shape-2 {
        width: 180px;
        height: 180px;
        bottom: -40px;
        left: -40px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.18);
        padding: 10px 20px;
        border-radius: 50px;
        color: #fff;
        font-weight: 600;
        margin-bottom: 25px;
        backdrop-filter: blur(10px);
    }

    .hero-title {
        color: #fff;
        font-size: 64px;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 25px;
    }

        .hero-title span {
            color: #8bb4ff;
        }

    .hero-subtitle {
        color: rgba(255,255,255,0.8);
        font-size: 18px;
        max-width: 750px;
        margin: auto;
        line-height: 1.8;
    }

    .hero-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    /* ================= CONTACT SECTION ================= */

    .contact-section {
        padding: 110px 0;
        background: var(--light-bg);
    }

    .contact-info-card,
    .contact-form-card {
        background: #fff;
        border-radius: 28px;
        padding: 40px;
        border: 1px solid var(--border);
        box-shadow: 0 15px 40px rgba(15, 23, 42, 0.06);
        height: 100%;
    }

    .section-mini-title {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 30px;
        background: rgba(21,101,255,0.08);
        color: var(--primary);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }

    .contact-side-title,
    .form-title,
    .map-title {
        font-size: 38px;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: 18px;
    }

    .contact-side-text,
    .form-subtitle,
    .map-subtitle {
        color: var(--text);
        line-height: 1.8;
        margin-bottom: 35px;
    }

    .contact-info-list {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 18px;
    }

    .contact-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

        .contact-icon.blue {
            background: rgba(21,101,255,0.12);
            color: #1565ff;
        }

        .contact-icon.green {
            background: rgba(25,135,84,0.12);
            color: #198754;
        }

        .contact-icon.orange {
            background: rgba(255,153,0,0.12);
            color: #ff9800;
        }

        .contact-icon.purple {
            background: rgba(111,66,193,0.12);
            color: #6f42c1;
        }

    .contact-item h6 {
        font-weight: 700;
        margin-bottom: 5px;
        color: var(--dark);
    }

    .contact-item p {
        margin: 0;
        color: var(--text);
    }

    /* ================= SOCIAL ================= */

    .social-wrapper {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #edf2f7;
    }

    .social-links {
        display: flex;
        gap: 12px;
    }

        .social-links a {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            background: #f4f8ff;
            color: var(--dark);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: 0.3s;
            font-size: 16px;
        }

            .social-links a:hover {
                background: var(--primary);
                color: #fff;
                transform: translateY(-4px);
            }

    /* ================= FORM ================= */

    .modern-input {
        margin-bottom: 24px;
    }

        .modern-input label {
            display: block;
            margin-bottom: 10px;
            font-weight: 600;
            color: var(--dark);
        }

        .modern-input input,
        .modern-input textarea {
            width: 100%;
            border: 1px solid #dbe4f0;
            background: #f8fbff;
            border-radius: 16px;
            padding: 16px 18px;
            outline: none;
            transition: 0.3s;
            font-size: 15px;
        }

            .modern-input input:focus,
            .modern-input textarea:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(21,101,255,0.08);
            }

    .submit-btn {
        border: none;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: #fff;
        padding: 16px 32px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 15px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: 0.3s;
        box-shadow: 0 15px 30px rgba(21,101,255,0.25);
    }

        .submit-btn:hover {
            transform: translateY(-4px);
        }

    /* ================= MAP ================= */

    .map-wrapper {
        background: #fff;
        padding-top: 100px;
    }

    .map-top-content {
        margin-bottom: 40px;
    }

    iframe {
        filter: grayscale(0.1);
    }

    /* ================= RESPONSIVE ================= */

    @@media(max-width:991px) {

        .hero-title {
            font-size: 44px;
        }

        .contact-side-title,
        .form-title,
        .map-title {
            font-size: 30px;
        }

        .contact-info-card,
        .contact-form-card {
            padding: 30px;
        }
    }

    @@media(max-width:576px) {

        .contact-hero {
            padding: 140px 0 90px;
        }

        .hero-title {
            font-size: 34px;
        }

        .hero-subtitle {
            font-size: 15px;
        }

        .hero-buttons {
            flex-direction: column;
        }

            .hero-buttons .btn {
                width: 100%;
            }
    }

</style>