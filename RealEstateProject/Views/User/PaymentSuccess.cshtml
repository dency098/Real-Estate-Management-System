@model RealEstateProject.Models.Enquiry
@{
    Layout = null;
    ViewData["Title"] = "Payment Success";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RealEstateProject</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #2563eb;
            --success: #10b981;
            --bg-main: #f8fafc;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Inter', system-ui, sans-serif;
            color: var(--text-dark);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .success-card {
            background: #fff;
            border-radius: 20px;
            padding: 40px;
            box-shadow: var(--card-shadow);
            width: 100%;
            max-width: 450px;
            text-align: center;
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 24px;
        }

        .amount {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 20px;
        }

        .detail-box {
            background: #f8fafc;
            border-radius: 12px;
            padding: 20px;
            margin-top: 24px;
            text-align: left;
            border: 1px solid #e2e8f0;
        }

        .detail-box p {
            margin-bottom: 8px;
            font-size: 0.95rem;
            display: flex;
            justify-content: space-between;
        }
        
        .detail-box p:last-child {
            margin-bottom: 0;
        }

        .detail-box strong {
            color: var(--text-muted);
            font-weight: 600;
        }

        .detail-box span {
            font-weight: 700;
            color: var(--text-dark);
        }

        .btn-custom {
            padding: 14px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            text-decoration: none;
            transition: 0.3s;
            display: inline-block;
            width: 100%;
            margin-top: 24px;
        }

        .btn-primary-custom {
            background: var(--primary);
            color: #fff;
            border: none;
        }

        .btn-primary-custom:hover {
            background: #1d4ed8;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
        }

        .btn-outline-custom {
            background: #fff;
            color: var(--text-dark);
            border: 1px solid #e2e8f0;
            margin-top: 12px;
        }

        .btn-outline-custom:hover {
            background: #f1f5f9;
            color: var(--primary);
        }
    </style>
</head>
<body>

    <div class="success-card">
        <!-- ✅ ICON -->
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>

        <!-- ✅ TITLE -->
        <h3 class="fw-bold text-success mb-2" style="color: var(--success) !important;">Payment Successful 🎉</h3>

        <!-- ✅ MESSAGE -->
        <p class="text-muted mb-4">
            Your payment has been processed securely.
        </p>

        <!-- ✅ AMOUNT -->
        <div class="amount mb-2">
            @if (Model.Stage >= 5)
            {
                <span>
                    ₹ @(((Model?.PropertyPrice ?? 0) * 0.02M).ToString("N0"))
                </span>
            }
            else
            {
                <span>₹ 15,000</span>
            }
        </div>

        <!-- ✅ DETAILS -->
        <div class="detail-box">
            <p><strong>Property</strong> <span>@(Model?.Property?.Title ?? "N/A")</span></p>
            <p><strong>Deal ID</strong> <span>#DEAL-@Model?.EnquiryId</span></p>
            <p><strong>Status</strong> <span>@Model?.Status</span></p>
            <p><strong>Date</strong> <span>@DateTime.Now.ToString("dd MMM yyyy")</span></p>
        </div>

        <!-- ✅ ACTION BUTTONS -->
        @if (Model.Stage == 6 || Model.Status == "Completed")
        {
            <a href="@Url.Action("DownloadInvoice", "User", new { id = Model.EnquiryId })" class="btn-custom btn-primary-custom">
                <i class="fas fa-file-download me-2"></i> Download Invoice
            </a>
        }

        <a href="@Url.Action("MyEnquiries", "User")" class="btn-custom btn-outline-custom">
            <i class="fas fa-arrow-left me-2"></i> Back to Deals
        </a>
    </div>

</body>
</html>
