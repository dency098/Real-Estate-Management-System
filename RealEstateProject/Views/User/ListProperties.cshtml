@model List<RealEstateProject.Models.Property>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #eef2f7, #d9e4f5);
    }

    .header h2 {
        font-weight: 700;
        color: #1e293b;
    }

    .btn-custom {
        border-radius: 30px;
        padding: 6px 18px;
        font-size: 14px;
    }

    /* CARD */
    .property-card {
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        transition: 0.4s;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        position: relative;
    }

        .property-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

    /* IMAGE */
    .img-box {
        position: relative;
        height: 230px;
        overflow: hidden;
    }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

    .property-card:hover img {
        transform: scale(1.1);
    }

    /* DARK OVERLAY */
    .overlay {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0.1));
    }

    /* BADGE */
    .badge-type {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(6px);
        color: #fff;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
    }

    /* PRICE */
    .price-tag {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background: #ffffff;
        color: #111;
        padding: 6px 12px;
        border-radius: 12px;
        font-weight: bold;
        font-size: 14px;
    }

    /* CARD BODY */
    .card-body {
        padding: 16px;
    }

    .title {
        font-size: 17px;
        font-weight: 600;
        color: #1e293b;
    }

    .location {
        font-size: 13px;
        color: #64748b;
        margin-top: 4px;
    }

    .user {
        font-size: 12px;
        color: #94a3b8;
    }

    /* BUTTON */
    .btn-view {
        display: block;
        margin-top: 12px;
        text-align: center;
        background: linear-gradient(45deg, #4f46e5, #3b82f6);
        color: white;
        padding: 7px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 13px;
        transition: 0.3s;
    }

        .btn-view:hover {
            background: linear-gradient(45deg, #4338ca, #2563eb);
            color: white;
        }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 header">
        <h2>🏡 Find Your Dream Property</h2>

    </div>

    <!-- CARDS -->
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="property-card">

                    <div class="img-box">
                        <img src="@(item.ProperyImages != null && item.ProperyImages.Any()
                                                                                                              ? item.ProperyImages.First().ImagePath
                                                                                                              : "/images/default.jpg")" />

                        <div class="overlay"></div>

                        <div class="badge-type">
                            @item.PropertyType
                        </div>

                        <div class="price-tag">
                            ₹ @item.Price
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="title">@item.Title</div>

                        <div class="location">
                            <i class="fa fa-location-dot"></i>
                            @(item.City?.CityName ?? "No City")
                        </div>

                        <div class="user">
                            <i class="fa fa-user"></i>
                            @(item.User?.FullName ?? "Unknown")
                        </div>

                        <a asp-controller="User" asp-action="ViewProperty" asp-route-id="@item.ProperyId" class="btn-sm-custom btn-view">
                            View
                        </a>

                    </div>

                </div>
            </div>
        }
    </div>

</div>@* @model List<RealEstateProject.Models.Property>

