@model IEnumerable<RealEstateProject.Models.Enquiry>

@{
    ViewData["Title"] = "My Property Deals";
    Layout = null;

    var userIdStr = Context.Session.GetString("UserId");
    var currentUserId = string.IsNullOrEmpty(userIdStr) ? 0 : Convert.ToInt32(userIdStr);
}
@using Microsoft.AspNetCore.Http

@{
    var fullName = Context.Session.GetString("FullName");

    var userImage = Context.Session.GetString("UserImage");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RealEstateProject</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        :root {
            --primary: #2563eb;
            --primary-light: #eff6ff;
            --sidebar-bg: #0f172a;
            --bg: #f4f7fb;
            --card: #ffffff;
            --text: #111827;
            --muted: #6b7280;
            --border: #e5e7eb;
            --success: #16a34a;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            font-family: 'Poppins',sans-serif;
            color: var(--text);
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        /* SIDEBAR */

        /* ===================================
           SIDEBAR
        =================================== */

        .sidebar {
            width: 240px;
            background: #0f172a;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            padding: 18px 14px;
            overflow-y: auto;
            z-index: 1000;
            transition: .3s;
        }

        /* BRAND */

        .brand-box {
            text-align: center;
            padding-bottom: 18px;
            margin-bottom: 18px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .brand-box img {
                width: 120px;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }

        /* USER */

        .user-mini {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 16px;
            background: rgba(255,255,255,.04);
            margin-bottom: 22px;
        }

            .user-mini img {
                width: 46px;
                height: 46px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,.15);
            }

            .user-mini h6 {
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                margin-bottom: 2px;
            }

            .user-mini p {
                color: #94a3b8;
                font-size: 11px;
                margin: 0;
            }

        /* NAVIGATION */

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .nav-links li {
                margin-bottom: 6px;
            }

                .nav-links li a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    color: #94a3b8;
                    text-decoration: none;
                    padding: 11px 14px;
                    border-radius: 14px;
                    font-size: 14px;
                    font-weight: 500;
                    transition: .25s;
                }

                    .nav-links li a i {
                        width: 18px;
                        font-size: 15px;
                    }

                    /* HOVER */

                    .nav-links li a:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                        transform: translateX(3px);
                    }

                /* ACTIVE */

                .nav-links li.active a {
                    background: #2563eb;
                    color: #fff;
                    box-shadow: 0 8px 20px rgba(37,99,235,.25);
                }

        /* LOGOUT */

        .logout-link {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .logout-link a {
                color: #f87171 !important;
            }

                .logout-link a:hover {
                    background: rgba(248,113,113,.12) !important;
                }

        /* MAIN CONTENT FIX */

        .main-content {
            margin-left: 240px;
            width: calc(100% - 240px);
            transition: .3s;
        }

        /* RESPONSIVE */

        @@media(max-width:992px) {

            .sidebar {
                width: 82px;
                padding: 16px 10px;
            }

            .brand-box img {
                width: 42px;
            }

            .user-mini {
                justify-content: center;
                padding: 10px;
            }

                .user-mini div {
                    display: none;
                }

            .nav-links li a {
                justify-content: center;
                padding: 12px;
            }

                .nav-links li a span {
                    display: none;
                }

            .main-content {
                margin-left: 82px;
                width: calc(100% - 82px);
            }
        }

        @@media(max-width:768px) {

            .sidebar {
                width: 72px;
            }

            .main-content {
                margin-left: 72px;
                width: calc(100% - 72px);
            }
        }

        /* MAIN */

        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 28px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

            .top-bar h2 {
                font-size: 24px;
                font-weight: 600;
                margin-bottom: 4px;
            }

            .top-bar p {
                color: var(--muted);
                font-size: 13px;
                margin: 0;
            }

        /* DEAL CARD */

        .deal-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            overflow: hidden;
            transition: .25s;
            height: 100%;
        }

            .deal-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.05);
            }

        .deal-image {
            position: relative;
            height: 190px;
            overflow: hidden;
        }

            .deal-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .deal-tag {
            position: absolute;
            top: 14px;
            left: 14px;
            padding: 6px 12px;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .5px;
        }

        .tag-buy {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .tag-sell {
            background: #dcfce7;
            color: #15803d;
        }

        .deal-content {
            padding: 18px;
        }

        .deal-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #111827;
        }

        .deal-price {
            font-size: 22px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 12px;
        }

        .deal-user {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--muted);
            font-size: 13px;
            margin-bottom: 18px;
        }

        /* STAGE */

        .stage-box {
            margin-bottom: 18px;
        }

        .stage-top {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 12px;
            font-weight: 500;
        }

            .stage-top span:last-child {
                color: var(--primary);
            }

        .custom-progress {
            width: 100%;
            height: 7px;
            border-radius: 30px;
            background: #e5e7eb;
            overflow: hidden;
        }

        .custom-progress-bar {
            height: 100%;
            border-radius: 30px;
            background: linear-gradient(to right,#2563eb,#60a5fa);
        }

        /* BUTTONS */

        .btn-custom {
            width: 100%;
            border: none;
            border-radius: 12px;
            padding: 11px;
            font-size: 13px;
            font-weight: 500;
            transition: .2s;
        }

        .btn-pay {
            background: var(--warning);
            color: #fff;
        }

            .btn-pay:hover {
                background: #d97706;
            }

        .btn-success-custom {
            background: var(--success);
            color: #fff;
        }

        .btn-disabled {
            background: #f3f4f6;
            color: #6b7280;
            cursor: not-allowed;
        }

        .btn-outline-custom {
            background: #fff;
            border: 1px solid var(--border);
            color: #111827;
        }

            .btn-outline-custom:hover {
                background: #f9fafb;
            }

        .button-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* EMPTY */

        .empty-box {
            background: #fff;
            border-radius: 18px;
            padding: 70px 20px;
            text-align: center;
            border: 1px solid var(--border);
        }

            .empty-box i {
                font-size: 55px;
                color: #cbd5e1;
                margin-bottom: 15px;
            }

            .empty-box h4 {
                font-size: 20px;
                font-weight: 600;
                margin-bottom: 8px;
            }

            .empty-box p {
                color: var(--muted);
                margin: 0;
                font-size: 14px;
            }

        @@media(max-width:992px) {

            .sidebar-menu-dashboard {
                width: 90px;
                padding: 20px 10px;
            }

            .logo-box img {
                width: 42px;
            }

            .nav-menu-link {
                justify-content: center;
            }

            .nav-menu-link {
                font-size: 0;
            }

                .nav-menu-link i {
                    font-size: 16px;
                    margin: 0;
                }

            .main-content {
                margin-left: 90px;
                width: calc(100% - 90px);
            }
        }

        @@media(max-width:768px) {

            .main-content {
                padding: 16px;
            }

            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }
        }

    </style>

</head>

<body>

    <div class="dashboard-wrapper">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand-box">
                <img src="@Url.Content("~/images/logo/logo-footer@2x.png")" />
            </div>

            <div class="user-mini">

                <img src="@Url.Content(userImage ?? "~/images/profile/default.png")" />

                <h6>@fullName</h6>

            </div>

            <ul class="nav-links">

                <li>
                    <a asp-controller="User" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Dashboard">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="active">
                    <a asp-controller="User" asp-action="Profile">
                        <i class="fa-solid fa-user"></i>
                        <span>My Profile</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyProperties">
                        <i class="fa-solid fa-building"></i>
                        <span>My Properties</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyEnquiries">
                        <i class="fa-solid fa-handshake"></i>
                        <span>Property Deals</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Property">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add Property</span>
                    </a>
                </li>

                <li class="logout-link">
                    <a asp-controller="Account"
                       asp-action="Logout"
                       onclick="return confirm('Logout?');">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </li>

            </ul>
<style>

        .btn-custom {
            width: 100%;
            border: none;
            border-radius: 12px;
            padding: 11px;
            font-size: 13px;
            font-weight: 500;
            transition: .2s;
        }

        .btn-pay {
            background: var(--warning);
            color: #fff;
        }

            .btn-pay:hover {
                background: #d97706;
            }

        .btn-success-custom {
            background: var(--success);
            color: #fff;
        }

        .btn-disabled {
            background: #f3f4f6;
            color: #6b7280;
            cursor: not-allowed;
        }

        .btn-outline-custom {
            background: #fff;
            border: 1px solid var(--border);
            color: #111827;
        }

            .btn-outline-custom:hover {
                background: #f9fafb;
            }

        .button-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* EMPTY */

        .empty-box {
            background: #fff;
            border-radius: 18px;
            padding: 70px 20px;
            text-align: center;
            border: 1px solid var(--border);
        }

            .empty-box i {
                font-size: 55px;
                color: #cbd5e1;
                margin-bottom: 15px;
            }

            .empty-box h4 {
                font-size: 20px;
                font-weight: 600;
                margin-bottom: 8px;
            }

            .empty-box p {
                color: var(--muted);
                margin: 0;
                font-size: 14px;
            }

        @@media(max-width:992px) {

            .sidebar-menu-dashboard {
                width: 90px;
                padding: 20px 10px;
            }

            .logo-box img {
                width: 42px;
            }

            .nav-menu-link {
                justify-content: center;
            }

            .nav-menu-link {
                font-size: 0;
            }

                .nav-menu-link i {
                    font-size: 16px;
                    margin: 0;
                }

            .main-content {
                margin-left: 90px;
                width: calc(100% - 90px);
            }
        }

        @@media(max-width:768px) {

            .main-content {
                padding: 16px;
            }

            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }
        }

    </style>


        </aside>

        <!-- MAIN -->

        <main class="main-content">

            <div class="top-bar">

                <div>
                    <h2>My Property Deals</h2>
                    <p>Track all your active property transactions</p>
                </div>

            </div>

            @if (!Model.Any())
            {
                <div class="empty-box">

                    <i class="fa-solid fa-folder-open"></i>

                    <h4>No Deals Found</h4>

                    <p>You don't have any active property deals yet.</p>

                </div>
            }
            else
            {
                <div class="row g-4">

                    @foreach (var item in Model)
                    {
                        bool isBuyer = item.SenderUserId == currentUserId;
                        bool isRent = string.Equals(item.Property?.PropertyType, "Rent", StringComparison.OrdinalIgnoreCase);
                        string userLabel = isRent ? "Tenant" : "Buyer";
                        decimal totalStages = isRent ? 6.0m : 7.0m;
                        decimal progress = item.Status == "Completed" ? 100 : (((item.Stage ?? 0) / totalStages) * 100);

                        <div class="col-lg-4 col-md-6">

                            <div class="deal-card">

                                <!-- IMAGE -->

                                <div class="deal-image">

                                    <img src="@Url.Content(item.Property?.ProperyImages?.FirstOrDefault()?.ImagePath ?? "~/images/default-property.jpg")" />

                                    <span class="deal-tag @(isBuyer ? "tag-buy" : "tag-sell")">
                                        @(isBuyer ? "BUYING" : "SELLING")
                                    </span>

                                </div>

                                <!-- CONTENT -->

                                <div class="deal-content">

                                    <div class="deal-title">
                                        @item.Property?.Title
                                    </div>

                                    <div class="deal-price">
                                        ₹ @((item.PropertyPrice ?? 0).ToString("N0"))
                                        @if (isRent)
                                        {
                                            <span style="font-size: 13px; font-weight: 500; color: var(--muted);">/ month</span>
                                        }
                                    </div>

                                    <div class="deal-user">
                                        <i class="fa-solid fa-user"></i>

                                        @(isBuyer
                                            ? $"Seller: {item.OwnerUser?.FullName}"
                                            : $"{userLabel}: {item.SenderUser?.FullName}")
                                    </div>

                                    <!-- PROGRESS -->

                                    <div class="stage-box">

                                        <div class="stage-top">
                                            <span>Stage @item.Stage / @((int)totalStages)</span>
                                            <span>@((int)progress)%</span>
                                        </div>

                                        <div class="custom-progress">
                                            <div class="custom-progress-bar"
                                                 style="width:@progress%">
                                            </div>
                                        </div>

                                    </div>

                                    <!-- BUTTONS -->

                                    <div class="button-group">

                                        @if (isRent)
                                        {
                                            <!-- ================= RENT PIPELINE BUTTONS ================= -->
                                            <!-- ================= RENT PIPELINE BUTTONS ================= -->
                                            @if (item.Stage == 1 || item.Stage == 2)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-calendar-days me-1 text-primary"></i> 2️⃣ Property Visiting</h6>
                                                    @if (string.IsNullOrEmpty(item.VisitStatus) || item.VisitStatus == "Pending" || item.VisitStatus == "Rejected")
                                                    {
                                                        @if (isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="RequestVisit" method="post" class="mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <div class="mb-2"><input type="date" name="preferredDate" required class="form-control form-control-sm" min="@DateTime.Now.ToString("yyyy-MM-dd")" style="font-size: 11px;" /></div>
                                                                <div class="mb-2">
                                                                    <select name="preferredTime" required class="form-select form-select-sm" style="font-size: 11px;">
                                                                        <option value="10:00 AM - 12:00 PM">Morning (10:00 AM - 12:00 PM)</option>
                                                                        <option value="02:00 PM - 04:00 PM">Afternoon (02:00 PM - 04:00 PM)</option>
                                                                    </select>
                                                                </div>
                                                                <button type="submit" class="btn btn-primary btn-sm w-100">Submit Visit Request</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-muted small" style="font-size: 11px;">Waiting for @userLabel.ToLower() to request a site visit.</span> }
                                                    }
                                                    else if (item.VisitStatus == "Requested")
                                                    {
                                                        <div class="alert alert-info py-1 px-2 mb-1 small" style="font-size: 11px;">Requested: @(item.PreferredVisitDate?.ToString("yyyy-MM-dd")) at @item.PreferredVisitTime</div>
                                                        @if (!isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="RespondToVisit" method="post" class="d-flex gap-1 mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <button type="submit" name="action" value="Approve" class="btn btn-sm btn-success flex-grow-1">Approve</button>
                                                                <button type="submit" name="action" value="Reject" class="btn btn-sm btn-danger flex-grow-1">Reject</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-warning small"><i class="fa-solid fa-spinner fa-spin"></i> Waiting for owner approval...</span> }
                                                    }
                                                    else if (item.VisitStatus == "Approved")
                                                    {
                                                        <div class="alert alert-success py-1 px-2 mb-1 small" style="font-size: 11px;">Approved: @(item.PreferredVisitDate?.ToString("yyyy-MM-dd"))</div>
                                                        @if (!isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="ProceedToStartDeal" method="post" class="mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <button type="submit" class="btn btn-sm btn-primary w-100">Start Official Deal</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-muted small">Waiting for owner to start the official deal.</span> }
                                                    }
                                                </div>
                                            }
                                            else if (item.Stage == 3)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-play me-1 text-success"></i> 3️⃣ Start Deal</h6>
                                                    <span class="text-muted small" style="font-size: 11px;">The official deal has started. Please proceed to upload your identity photo.</span>
                                                    @if (isBuyer) {
                                                        <form asp-controller="User" asp-action="AdvanceToDocuments" method="post" class="mt-2">
                                                            <input type="hidden" name="id" value="@item.EnquiryId" />
                                                            <button type="submit" class="btn btn-sm btn-success w-100">Upload Documents Now</button>
                                                        </form>
                                                    }
                                                </div>
                                            }
                                            else if (item.Stage == 4)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-id-card me-1 text-primary"></i> 4️⃣ Document</h6>
                                                    @if (isBuyer)
                                                    {
                                                        <form asp-controller="User" asp-action="UploadDocuments" method="post" enctype="multipart/form-data" class="mt-2">
                                                            <input type="hidden" name="id" value="@item.EnquiryId" />
                                                            <input type="file" name="documentFile" required class="form-control form-control-sm mb-2" style="font-size: 11px;" />
                                                            <button type="submit" class="btn btn-primary btn-sm w-100">Upload Identity Photo</button>
                                                        </form>
                                                    }
                                                    else { <span class="text-muted small">Waiting for @userLabel.ToLower() to upload identity photo.</span> }
                                                </div>
                                            }
                                            else if (item.Stage == 5)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-money-bill-wave me-1 text-success"></i> 5️⃣ Pay Deposit & 1 Month Rent</h6>
                                                    @if (isBuyer)
                                                    {
                                                        <a href="@Url.Action("InitiatePayment", "User", new { id = item.EnquiryId, paymentType = "RentDepositAndFirstMonth" })" class="btn btn-sm btn-success w-100 mb-1">Pay Deposit & Rent (₹@(((item.PropertyPrice ?? 0) * 4).ToString("N0")))</a>
                                                    }
                                                    else { <span class="text-muted small">Waiting for @userLabel.ToLower() to pay deposit and first month rent.</span> }
                                                </div>
                                            }
                                            else if (item.Stage == 6 && item.Status != "Completed")
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-handshake me-1 text-primary"></i> 6️⃣ Pay Brokering Charge</h6>
                                                    @if (isBuyer)
                                                    {
                                                        <a href="@Url.Action("InitiatePayment", "User", new { id = item.EnquiryId, paymentType = "RentBrokerage" })" class="btn btn-sm btn-primary w-100 mb-1">Pay Brokerage (₹@((item.PropertyPrice ?? 0).ToString("N0")))</a>
                                                    }
                                                    else { <span class="text-muted small">Waiting for @userLabel.ToLower() to pay brokering charges.</span> }
                                                </div>
                                            }
                                            else if (item.Status == "Completed")
                                            {
                                                <div class="p-3 border rounded bg-success-subtle mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-success" style="font-size: 13px;"><i class="fa-solid fa-check-double me-1"></i> Active Lease</h6>
                                                    
                                                    @if (item.IsCloseRentRequested)
                                                    {
                                                        <div class="alert alert-warning py-2 px-3 mb-0" style="font-size: 12px;">
                                                            <i class="fa-solid fa-clock me-1"></i> <strong>Closure requested.</strong> Waiting for admin to close the deal.
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small d-block mb-3" style="font-size: 11px;">Your rent deal is currently active. You can request closure when you move out.</span>
                                                    
                                                        @if (isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="RequestCloseRentDeal" method="post" onsubmit="return confirm('Request admin to close this rent deal?');">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                                    <i class="fa-solid fa-circle-xmark me-1"></i> Request to Close Rent Deal
                                                                </button>
                                                            </form>
                                                        }
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <!-- ================= SALE PIPELINE BUTTONS (7 STAGES) ================= -->
                                            @if (item.Stage == 1 || item.Stage == 2)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-calendar-days me-1 text-primary"></i> 2️⃣ Property Visiting</h6>
                                                    @if (string.IsNullOrEmpty(item.VisitStatus) || item.VisitStatus == "Pending" || item.VisitStatus == "Rejected")
                                                    {
                                                        @if (isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="RequestVisit" method="post" class="mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <div class="mb-2"><input type="date" name="preferredDate" required class="form-control form-control-sm" min="@DateTime.Now.ToString("yyyy-MM-dd")" style="font-size: 11px;" /></div>
                                                                <div class="mb-2">
                                                                    <select name="preferredTime" required class="form-select form-select-sm" style="font-size: 11px;">
                                                                        <option value="10:00 AM - 12:00 PM">Morning (10:00 AM - 12:00 PM)</option>
                                                                        <option value="02:00 PM - 04:00 PM">Afternoon (02:00 PM - 04:00 PM)</option>
                                                                    </select>
                                                                </div>
                                                                <button type="submit" class="btn btn-primary btn-sm w-100">Submit Visit Request</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-muted small" style="font-size: 11px;">Waiting for @userLabel.ToLower() to request a site visit.</span> }
                                                    }
                                                    else if (item.VisitStatus == "Requested")
                                                    {
                                                        <div class="alert alert-info py-1 px-2 mb-1 small" style="font-size: 11px;">Requested: @(item.PreferredVisitDate?.ToString("yyyy-MM-dd"))</div>
                                                        @if (!isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="RespondToVisit" method="post" class="d-flex gap-1 mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <button type="submit" name="action" value="Approve" class="btn btn-sm btn-success flex-grow-1">Approve</button>
                                                                <button type="submit" name="action" value="Reject" class="btn btn-sm btn-danger flex-grow-1">Reject</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-warning small"><i class="fa-solid fa-spinner fa-spin"></i> Waiting for owner approval...</span> }
                                                    }
                                                    else if (item.VisitStatus == "Approved")
                                                    {
                                                        <div class="alert alert-success py-1 px-2 mb-1 small" style="font-size: 11px;">Approved: @(item.PreferredVisitDate?.ToString("yyyy-MM-dd"))</div>
                                                        @if (!isBuyer)
                                                        {
                                                            <form asp-controller="User" asp-action="ProceedToStartDeal" method="post" class="mt-2">
                                                                <input type="hidden" name="id" value="@item.EnquiryId" />
                                                                <button type="submit" class="btn btn-sm btn-primary w-100">Start Official Deal</button>
                                                            </form>
                                                        }
                                                        else { <span class="text-muted small">Waiting for owner to start the official deal.</span> }
                                                    }
                                                </div>
                                            }
                                            else if (item.Stage == 3)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-play me-1 text-success"></i> 3️⃣ Start Deal</h6>
                                                    <span class="text-muted small" style="font-size: 11px;">Official deal has started. Please proceed to upload your documents.</span>
                                                    @if (isBuyer) {
                                                        <form asp-controller="User" asp-action="AdvanceToDocuments" method="post" class="mt-2">
                                                            <input type="hidden" name="id" value="@item.EnquiryId" />
                                                            <button type="submit" class="btn btn-sm btn-success w-100">Proceed to Documents</button>
                                                        </form>
                                                    }
                                                </div>
                                            }
                                            else if (item.Stage == 4)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-id-card me-1 text-primary"></i> 4️⃣ Document Verification</h6>
                                                    @if (isBuyer)
                                                    {
                                                        <form asp-controller="User" asp-action="UploadDocuments" method="post" enctype="multipart/form-data" class="mt-2">
                                                            <input type="hidden" name="id" value="@item.EnquiryId" />
                                                            <input type="file" name="documentFile" required class="form-control form-control-sm mb-2" style="font-size: 11px;" />
                                                            <button type="submit" class="btn btn-primary btn-sm w-100">Upload Identity Proof</button>
                                                        </form>
                                                    }
                                                    else { <span class="text-muted small">Waiting for @userLabel.ToLower() to upload identity proof.</span> }
                                                </div>
                                            }
                                            else if (item.Stage == 5)
                                            {
                                                @if (isBuyer && !item.IsTokenPaid)
                                                {
                                                    <a href="@Url.Action("InitiatePayment", "User", new { id = item.EnquiryId, paymentType = "Token" })"
                                                       class="btn-custom btn-pay text-center" style="display: block; text-decoration:none;">
                                                        <i class="fa-solid fa-wallet me-1"></i>
                                                        Pay Token ₹15,000
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn-custom btn-disabled text-center">
                                                        <i class="fa-solid fa-clock me-1"></i>
                                                        @(item.IsTokenPaid ? "Token Paid - Processing Registration" : "Waiting for " + userLabel + " Token Payment")
                                                    </button>
                                                }
                                            }
                                            else if (item.Stage == 6)
                                            {
                                                <div class="p-3 border rounded bg-white shadow-sm mb-3 text-start">
                                                    <h6 class="fw-bold mb-2 text-dark" style="font-size: 13px;"><i class="fa-solid fa-file-contract me-1 text-primary"></i> 6️⃣ Legal Registration</h6>
                                                    <span class="text-muted small" style="font-size: 11px;">Legal transfer process is underway. Please wait for completion.</span>
                                                </div>
                                            }
                                            else if (item.Stage == 7 && !item.IsCommissionPaid)
                                            {
                                                bool hasUserPaid = (isBuyer && item.IsCommissionPaidByBuyer) || (!isBuyer && item.IsCommissionPaidByOwner);

                                                @if (!hasUserPaid)
                                                {
                                                    <a href="@Url.Action("InitiatePayment", "User", new { id = item.EnquiryId, paymentType = "Commission" })"
                                                       class="btn-custom btn-pay text-center" style="display: block; text-decoration:none;">
                                                        <i class="fa-solid fa-file-invoice-dollar me-1"></i>
                                                        Pay Commission
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn-custom btn-disabled text-center" style="margin-bottom:10px;">
                                                        <i class="fa-solid fa-check-circle me-1"></i>
                                                        Commission Paid
                                                    </button>
                                                    <div class="text-center text-muted small">Waiting for @(isBuyer ? "Seller" : userLabel) to pay...</div>
                                                }
                                            }
                                            else if (item.Status == "Completed" || item.Property?.Status == "Sold" || item.IsCommissionPaid)
                                            {
                                                <button class="btn-custom btn-success-custom text-center" style="pointer-events: none; margin-bottom:10px;">
                                                    <i class="fa-solid fa-circle-check me-1"></i>
                                                    Deal Completed
                                                </button>

                                                <a href="@Url.Action("DownloadInvoice", "User", new { id = item.EnquiryId })"
                                                   class="btn-custom btn-outline-custom text-center" style="display: block; text-decoration:none; margin-bottom:10px;">
                                                    <i class="fa-solid fa-file-pdf me-1"></i>
                                                    Download Invoice
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn-custom btn-disabled text-center">
                                                    <i class="fa-solid fa-spinner fa-spin me-1"></i>
                                                    Processing Stage @item.Stage...
                                                </button>
                                            }
                                        }

                                        <a href="@Url.Action("ViewProperty", "User", new { id = item.PropertyId })"
                                           class="btn-custom btn-outline-custom text-center" style="display: block;">
                                            <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>
                                            View Property
                                        </a>

                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>