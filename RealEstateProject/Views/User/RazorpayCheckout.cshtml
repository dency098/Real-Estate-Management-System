@model RealEstateProject.Models.Enquiry
@{
    Layout = null;
    ViewData["Title"] = "Secure Checkout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RealEstateProject</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #2563eb;
            --bg-main: #f8fafc;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Inter', system-ui, sans-serif;
            color: var(--text-dark);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .payment-card {
            background: #fff;
            border-radius: 20px;
            padding: 40px;
            box-shadow: var(--card-shadow);
            width: 100%;
            max-width: 450px;
            text-align: center;
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .payment-icon {
            width: 80px;
            height: 80px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 24px;
        }

        .amount {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 20px;
        }

        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid var(--primary);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        .btn-primary:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
        }
    </style>
</head>
<body>

    <div class="payment-card">
        <!-- Icon -->
        <div class="payment-icon">
            <i class="fas fa-lock"></i>
        </div>

        <!-- Title -->
        <h4 class="fw-bold mb-2">
            Processing @ViewBag.PaymentType Payment
        </h4>

        <!-- Amount -->
        <h2 class="amount mb-3">
            ₹ @(ViewBag.Amount != null ? ((decimal)ViewBag.Amount).ToString("N0") : "0")
        </h2>

        <!-- Info -->
        <p class="text-muted mb-4">
            Secure payment powered by Razorpay.<br />
            Please do not refresh this page.
        </p>

        <!-- Loader -->
        <div class="loader mb-4" id="loader"></div>

        <!-- Button -->
        <button id="rzp-button1" class="btn btn-primary w-100" style="display:none;" onclick="rzp1.open();">
            <i class="fas fa-credit-card me-2"></i> Pay Now
        </button>

        <a href="@Url.Action("MyEnquiries", "User")" class="btn btn-light w-100 mt-3" style="font-weight: 600; border-radius: 12px; padding: 12px;">
            Cancel
        </a>

        <!-- Footer -->
        <small class="text-muted d-block mt-4">
            <i class="fa-solid fa-shield-halved me-1"></i> 100% Secure Encrypted Payment
        </small>
    </div>

    <!-- ✅ HIDDEN FORM (POST) -->
    <form id="paymentForm" method="post" action="@Url.Action("VerifyPayment","User")">
        <input type="hidden" name="razorpay_payment_id" id="razorpay_payment_id" />
        <input type="hidden" name="razorpay_order_id" id="razorpay_order_id" />
        <input type="hidden" name="razorpay_signature" id="razorpay_signature" />
        <input type="hidden" name="enquiryId" value="@(Model?.EnquiryId ?? 0)" />
        <input type="hidden" name="paymentType" value="@ViewBag.PaymentType" />
    </form>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        var options = {
            "key": "@ViewBag.KeyId",
            "amount": "@((int)((decimal)(ViewBag.Amount ?? 0m) * 100))",
            "currency": "INR",
            "name": "Real Estate Co.",
            "description": "@(ViewBag.PaymentType ?? "Payment") for @(Model?.Property?.Title ?? "Property")",
            "order_id": "@ViewBag.OrderId",

            "method": {
                "upi": true
            },

            "config": {
                "display": {
                    "blocks": {
                        "upi": {
                            "name": "Pay via UPI",
                            "instruments": [
                                { "method": "upi" }
                            ]
                        }
                    },
                    "sequence": ["block.upi"],
                    "preferences": {
                        "show_default_blocks": true
                    }
                }
            },

            "handler": function (response) {
                document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                document.getElementById('razorpay_order_id').value = response.razorpay_order_id;
                document.getElementById('razorpay_signature').value = response.razorpay_signature;

                document.getElementById('loader').style.display = 'block';
                document.getElementById('rzp-button1').style.display = 'none';
                
                document.getElementById('paymentForm').submit(); // ✅ THIS CALLS POST
            },

            "modal": {
                "ondismiss": function () {
                    document.getElementById('loader').style.display = 'none';
                    document.getElementById('rzp-button1').style.display = 'block';
                }
            },

            "prefill": {
                "name": "@(Model?.SenderUser?.FullName ?? "User")",
                "email": "@(Model?.SenderUser?.Email ?? "test@email.com")"
            },

            "theme": {
                "color": "#2563eb"
            }
        };

        var rzp1 = new Razorpay(options);

        window.onload = function () {
            rzp1.open();
        };
    </script>
</body>
</html>
