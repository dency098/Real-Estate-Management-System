@model RealEstateProject.Models.User

@{
    Layout = null;
    ViewData["Title"] = "My Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - RealEstateProject</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>

        :root {
            --primary: #2563eb;
            --primary2: #4f46e5;
            --bg: #f4f7fb;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e2e8f0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter',sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        /* =========================
                        LAYOUT
                ========================== */

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
        }

        /* ===================================
           SIDEBAR
        =================================== */

        .sidebar {
            width: 240px;
            background: #0f172a;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            padding: 18px 14px;
            overflow-y: auto;
            z-index: 1000;
            transition: .3s;
        }

        /* BRAND */

        .brand-box {
            text-align: center;
            padding-bottom: 18px;
            margin-bottom: 18px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .brand-box img {
                width: 120px;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }

        /* USER */

        .user-mini {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 16px;
            background: rgba(255,255,255,.04);
            margin-bottom: 22px;
        }

            .user-mini img {
                width: 46px;
                height: 46px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,.15);
            }

            .user-mini h6 {
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                margin-bottom: 2px;
            }

            .user-mini p {
                color: #94a3b8;
                font-size: 11px;
                margin: 0;
            }

        /* NAVIGATION */

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .nav-links li {
                margin-bottom: 6px;
            }

                .nav-links li a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    color: #94a3b8;
                    text-decoration: none;
                    padding: 11px 14px;
                    border-radius: 14px;
                    font-size: 14px;
                    font-weight: 500;
                    transition: .25s;
                }

                    .nav-links li a i {
                        width: 18px;
                        font-size: 15px;
                    }

                    /* HOVER */

                    .nav-links li a:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                        transform: translateX(3px);
                    }

                /* ACTIVE */

                .nav-links li.active a {
                    background: #2563eb;
                    color: #fff;
                    box-shadow: 0 8px 20px rgba(37,99,235,.25);
                }

        /* LOGOUT */

        .logout-link {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .logout-link a {
                color: #f87171 !important;
            }

                .logout-link a:hover {
                    background: rgba(248,113,113,.12) !important;
                }

        /* MAIN CONTENT FIX */

        .main-content {
            margin-left: 240px;
            width: calc(100% - 240px);
            transition: .3s;
        }

        /* RESPONSIVE */

        @@media(max-width:992px) {

            .sidebar {
                width: 82px;
                padding: 16px 10px;
            }

            .brand-box img {
                width: 42px;
            }

            .user-mini {
                justify-content: center;
                padding: 10px;
            }

                .user-mini div {
                    display: none;
                }

            .nav-links li a {
                justify-content: center;
                padding: 12px;
            }

                .nav-links li a span {
                    display: none;
                }

            .main-content {
                margin-left: 82px;
                width: calc(100% - 82px);
            }
        }

        @@media(max-width:768px) {

            .sidebar {
                width: 72px;
            }

            .main-content {
                margin-left: 72px;
                width: calc(100% - 72px);
            }
        }
        /* =========================
                        MAIN CONTENT
                ========================== */

        .main-content {
            margin-left: 290px;
            width: calc(100% - 290px);
            padding: 35px;
        }

        /* =========================
                        TOPBAR
                ========================== */

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

            .topbar h2 {
                font-size: 34px;
                font-weight: 800;
            }

            .topbar p {
                margin: 0;
                color: var(--muted);
            }

        .topbar-actions {
            display: flex;
            gap: 14px;
        }

        .glass-btn {
            height: 52px;
            padding: 0 22px;
            border: none;
            border-radius: 16px;
            background: #fff;
            border: 1px solid var(--border);
            font-weight: 700;
            transition: .3s;
        }

            .glass-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 25px rgba(0,0,0,.06);
            }

        .primary-btn {
            background: linear-gradient(135deg,var(--primary),var(--primary2));
            color: #fff;
        }

        /* =========================
                        HERO SECTION
                ========================== */

        .profile-hero {
            position: relative;
            overflow: hidden;
            border-radius: 35px;
            padding: 40px;
            margin-bottom: 30px;
            background: linear-gradient(135deg,rgba(37,99,235,.95),rgba(79,70,229,.95)), url('/images/banner/banner.jpg');
            background-size: cover;
            background-position: center;
            box-shadow: 0 25px 60px rgba(37,99,235,.18);
        }

        .hero-pattern {
            position: absolute;
            inset: 0;
            opacity: .08;
            background-image: radial-gradient(#fff 1px, transparent 1px);
            background-size: 22px 22px;
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero-flex {
            display: flex;
            align-items: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .hero-avatar {
            position: relative;
        }

            .hero-avatar img {
                width: 155px;
                height: 155px;
                border-radius: 30px;
                object-fit: cover;
                border: 5px solid rgba(255,255,255,.18);
                box-shadow: 0 20px 40px rgba(0,0,0,.18);
            }

        .online-dot {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #10b981;
            position: absolute;
            right: 10px;
            bottom: 10px;
            border: 4px solid #fff;
        }

        .member-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            border-radius: 40px;
            background: rgba(255,255,255,.15);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .hero-details h1 {
            color: #fff;
            font-size: 42px;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .hero-details p {
            color: rgba(255,255,255,.85);
            line-height: 1.7;
            margin-bottom: 20px;
        }

        .hero-meta {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .meta-pill {
            background: rgba(255,255,255,.14);
            color: #fff;
            padding: 12px 18px;
            border-radius: 16px;
            font-size: 14px;
        }

        /* =========================
                        CARDS
                ========================== */

        .content-card {
            background: #fff;
            border-radius: 30px;
            padding: 30px;
            border: 1px solid var(--border);
            box-shadow: 0 10px 35px rgba(15,23,42,.04);
            height: 100%;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

            .section-header h4 {
                font-size: 24px;
                font-weight: 800;
                margin-bottom: 5px;
            }

            .section-header p {
                margin: 0;
                color: var(--muted);
            }

        .mini-btn {
            width: 44px;
            height: 44px;
            border: none;
            border-radius: 14px;
            background: #eff6ff;
            color: var(--primary);
        }

        /* =========================
                        INFO GRID
                ========================== */

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2,1fr);
            gap: 20px;
        }

        .info-item {
            background: #f8fafc;
            border: 1px solid #edf2f7;
            border-radius: 22px;
            padding: 24px;
            transition: .3s;
        }

            .info-item:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 25px rgba(0,0,0,.05);
            }

            .info-item span {
                display: block;
                color: var(--muted);
                font-size: 12px;
                font-weight: 700;
                margin-bottom: 8px;
                text-transform: uppercase;
            }

            .info-item h6 {
                margin: 0;
                font-size: 17px;
                font-weight: 700;
            }

        /* =========================
                        PROFILE STATUS
                ========================== */

        .status-card {
            background: linear-gradient(135deg,var(--primary),var(--primary2));
            color: #fff;
            border-radius: 30px;
            padding: 35px;
            position: relative;
            overflow: hidden;
        }

            .status-card::before {
                content: '';
                position: absolute;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(255,255,255,.08);
                top: -100px;
                right: -80px;
            }

        .status-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            background: rgba(255,255,255,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 24px;
        }

        .status-card h2 {
            font-size: 52px;
            font-weight: 800;
        }

        .progress {
            height: 10px;
            border-radius: 20px;
            overflow: hidden;
            background: rgba(255,255,255,.2);
        }

        .progress-bar {
            width: 92%;
            background: #fff;
        }

        /* =========================
                        FORM
                ========================== */

        .modern-input {
            height: 58px;
            border-radius: 18px;
            border: 1px solid #dbe4ee;
            background: #f8fafc;
            padding: 0 18px;
        }

            .modern-input:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 5px rgba(37,99,235,.08);
            }

        .save-profile-btn {
            height: 58px;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg,var(--primary),var(--primary2));
            color: #fff;
            font-weight: 700;
            width: 100%;
        }

        /* =========================
                        RESPONSIVE
                ========================== */

        @@media(max-width:992px) {

            .sidebar {
                width: 90px;
                padding: 20px 10px;
            }

            .brand-box img {
                width: 45px;
            }

            .user-mini div,
            .nav-links a span {
                display: none;
            }

            .main-content {
                margin-left: 90px;
                width: calc(100% - 90px);
            }
        }

        @@media(max-width:768px) {

            .main-content {
                padding: 15px;
            }

            .profile-hero {
                padding: 30px 20px;
            }

            .hero-flex {
                justify-content: center;
                text-align: center;
            }

            .hero-meta {
                justify-content: center;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }

            .hero-details h1 {
                font-size: 30px;
            }

            .hero-avatar img {
                width: 120px;
                height: 120px;
            }
        }
        /* ========================================
           ACTIVITY CARD
        ======================================== */

        .activity-card {
            background: #fff;
            border-radius: 30px;
            padding: 32px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 15px 40px rgba(15,23,42,0.05);
            height: 100%;
            position: relative;
            overflow: hidden;
        }

            .activity-card::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 180px;
                height: 180px;
                background: linear-gradient(135deg,#2563eb20,#4f46e520);
                border-radius: 50%;
            }

        .activity-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            position: relative;
            z-index: 2;
        }

        .activity-icon {
            width: 68px;
            height: 68px;
            border-radius: 22px;
            background: linear-gradient(135deg,#2563eb,#4f46e5);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            box-shadow: 0 15px 30px rgba(37,99,235,0.25);
        }

        .activity-badge {
            background: #dcfce7;
            color: #15803d;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 700;
        }

        .activity-title {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 12px;
            color: #0f172a;
            position: relative;
            z-index: 2;
        }

        .activity-text {
            color: #64748b;
            line-height: 1.7;
            margin-bottom: 28px;
            position: relative;
            z-index: 2;
        }

        .activity-list {
            display: flex;
            flex-direction: column;
            gap: 18px;
            position: relative;
            z-index: 2;
        }

        .activity-item {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            padding: 18px;
            border-radius: 22px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
            transition: 0.3s;
        }

            .activity-item:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 24px rgba(0,0,0,0.05);
            }

        .activity-item-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
            color: #fff;
        }

        .blue-bg {
            background: linear-gradient(135deg,#2563eb,#3b82f6);
        }

        .green-bg {
            background: linear-gradient(135deg,#059669,#10b981);
        }

        .purple-bg {
            background: linear-gradient(135deg,#7c3aed,#8b5cf6);
        }

        .activity-item h6 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 4px;
            color: #0f172a;
        }

        .activity-item span {
            font-size: 13px;
            color: #64748b;
        }

        .activity-btn {
            width: 100%;
            height: 56px;
            border: none;
            border-radius: 18px;
            margin-top: 28px;
            background: linear-gradient(135deg,#2563eb,#4f46e5);
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            transition: 0.3s;
            position: relative;
            z-index: 2;
        }

            .activity-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 18px 35px rgba(37,99,235,0.25);
            }
    </style>
</head>

<body>

    <div class="dashboard-layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand-box">
                <img src="@Url.Content("~/images/logo/logo-footer@2x.png")" />
            </div>

            <div class="user-mini">

                <img src="@(string.IsNullOrEmpty(Model.ProfileImage)
                                     ? Url.Content("~/images/profile/default.png")
                                     : Url.Content(Model.ProfileImage))" />

                <div>
                    <h6>@Model.FullName</h6>
                   
                </div>

            </div>

            <ul class="nav-links">

                <li>
                    <a asp-controller="User" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Dashboard">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="active">
                    <a asp-controller="User" asp-action="Profile">
                        <i class="fa-solid fa-user"></i>
                        <span>My Profile</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyProperties">
                        <i class="fa-solid fa-building"></i>
                        <span>My Properties</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="MyEnquiries">
                        <i class="fa-solid fa-handshake"></i>
                        <span>Property Deals</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="User" asp-action="Property">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add Property</span>
                    </a>
                </li>

                <li class="logout-link">
                    <a asp-controller="Account"
                       asp-action="Logout"
                       onclick="return confirm('Logout?');">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </li>

            </ul>

        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">

                <div>
                    <h2>My Profile</h2>
                    <p>Manage your account and personal details.</p>
                </div>

                <div class="topbar-actions">

                    <button class="glass-btn" onclick="toggleEdit()">
                        <i class="fa-solid fa-pen me-2"></i>Edit
                    </button>

                    <button class="glass-btn primary-btn">
                        <i class="fa-solid fa-circle-check me-2"></i>Verified
                    </button>

                </div>

            </div>

            <!-- HERO -->
            <div class="profile-hero">

                <div class="hero-pattern"></div>

                <div class="hero-content">

                    <div class="hero-flex">

                        <div class="hero-avatar">

                            <img src="@(string.IsNullOrEmpty(Model.ProfileImage)
                                                             ? Url.Content("~/images/profile/default.png")
                                                             : Url.Content(Model.ProfileImage))" />

                            <span class="online-dot"></span>

                        </div>

                        <div class="hero-details">

                            <div class="member-badge">
                                <i class="fa-solid fa-crown"></i>
                                Premium Member
                            </div>

                            <h1>@Model.FullName</h1>

                            <p>
                                Professional real estate member with verified profile activity and trusted listings.
                            </p>

                            <div class="hero-meta">

                                <div class="meta-pill">
                                    <i class="fa-solid fa-envelope me-2"></i>
                                    @Model.Email
                                </div>

                                <div class="meta-pill">
                                    <i class="fa-solid fa-phone me-2"></i>
                                    @Model.Phone
                                </div>

                                <div class="meta-pill">
                                    <i class="fa-solid fa-calendar me-2"></i>
                                    Joined @Model.CreatedAt.ToString("MMM yyyy")
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- CONTENT -->
            <div class="row g-4">

                <!-- LEFT -->
                <div class="col-lg-8">

                    <div class="content-card">

                        <div class="section-header">

                            <div>
                                <h4>Personal Information</h4>
                                <p>Your profile and contact details.</p>
                            </div>

                            <button class="mini-btn" onclick="toggleEdit()">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                        </div>

                        <div class="info-grid">

                            <div class="info-item">
                                <span>Full Name</span>
                                <h6>@Model.FullName</h6>
                            </div>

                            <div class="info-item">
                                <span>Email</span>
                                <h6>@Model.Email</h6>
                            </div>

                            <div class="info-item">
                                <span>Phone</span>
                                <h6>@Model.Phone</h6>
                            </div>

                            <div class="info-item">
                                <span>Joined</span>
                                <h6>@Model.CreatedAt.ToString("MMMM dd, yyyy")</h6>
                            </div>

                        </div>

                    </div>

                    <!-- EDIT -->
                    <div class="content-card mt-4"
                         id="editSection"
                         style="display:none;">

                        <div class="section-header">

                            <div>
                                <h4>Edit Profile</h4>
                                <p>Update your account details.</p>
                            </div>

                        </div>

                        <form asp-action="UpdateProfile"
                              method="post"
                              enctype="multipart/form-data">

                            <input type="hidden" asp-for="UserId" />

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label fw-semibold">
                                        Full Name
                                    </label>

                                    <input asp-for="FullName"
                                           class="form-control modern-input" />

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label fw-semibold">
                                        Phone
                                    </label>

                                    <input asp-for="Phone"
                                           class="form-control modern-input" />

                                </div>

                            </div>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">
                                    Email
                                </label>

                                <input asp-for="Email"
                                       class="form-control modern-input" />

                            </div>

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Profile Image
                                </label>

                                <input type="file"
                                       name="ImageFile"
                                       class="form-control modern-input" />

                            </div>

                            <button type="submit" class="save-profile-btn">
                                <i class="fa-solid fa-floppy-disk me-2"></i>
                                Save Changes
                            </button>

                        </form>

                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-lg-4">

                    <div class="activity-card">

                        <div class="activity-top">

                            <div class="activity-icon">
                                <i class="fa-solid fa-chart-line"></i>
                            </div>

                            <div>
                                <span class="activity-badge">
                                    Active Account
                                </span>
                            </div>

                        </div>

                        <h4 class="activity-title">
                            Your Profile Activity
                        </h4>

                        <p class="activity-text">
                            Keep your profile updated to attract more buyers and build trust with property enquiries.
                        </p>

                        <div class="activity-list">

