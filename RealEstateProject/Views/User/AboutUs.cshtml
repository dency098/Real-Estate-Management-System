@{
    ViewData["Title"] = "About Us";
}

<!-- ================= HERO SECTION ================= -->
<section class="about-hero position-relative overflow-hidden">

    <div class="hero-pattern"></div>

    <div class="container position-relative z-2">
        <div class="row align-items-center min-vh-75">

            <!-- LEFT -->
            <div class="col-lg-6">

                <div class="hero-badge mb-4">
                    <i class="fa-solid fa-building-circle-check"></i>
                    Trusted Real Estate Platform
                </div>

                <h1 class="hero-title">
                    Find Your Perfect
                    <span>Dream Property</span>
                    With Confidence
                </h1>

                <p class="hero-desc">
                    We help thousands of people discover premium homes,
                    apartments, villas, and investment properties with
                    complete transparency and trust.
                </p>

                <div class="hero-buttons d-flex flex-wrap gap-3">

                    <a asp-controller="User"
                       asp-action="Listing"
                       class="btn btn-primary-custom">
                        Explore Properties
                    </a>

                    <a asp-controller="User"
                       asp-action="ContactUs"
                       class="btn btn-outline-custom">
                        Contact Us
                    </a>

                </div>

                <!-- STATS -->
                <div class="hero-stats">

                    <div class="stat-box">
                        <h3>12K+</h3>
                        <p>Properties Listed</p>
                    </div>

                    <div class="stat-box">
                        <h3>5K+</h3>
                        <p>Happy Clients</p>
                    </div>

                    <div class="stat-box">
                        <h3>24/7</h3>
                        <p>Customer Support</p>
                    </div>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-6">

                <div class="hero-images">

                    <div class="img-main">
                        <img src="@Url.Content("~/images/banner/banner-property-5.jpg")"
                             alt="property">
                    </div>

                    <div class="img-small img-small-1">
                        <img src="@Url.Content("~/images/banner/banner-property-6.jpg")"
                             alt="property">
                    </div>

                    <div class="img-small img-small-2">
                        <img src="@Url.Content("~/images/banner/banner-property-7.jpg")"
                             alt="property">
                    </div>

                    <!-- FLOAT CARD -->
                    <div class="floating-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="float-icon">
                                <i class="fa-solid fa-house"></i>
                            </div>

                            <div>
                                <h6>Premium Properties</h6>
                                <p>Verified Listings</p>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>
</section>

<!-- ================= ABOUT SECTION ================= -->
<section class="about-section">

    <div class="container">

        <div class="row align-items-center g-5">

            <!-- IMAGES -->
            <div class="col-lg-6">

                <div class="about-image-grid">

                    <div class="about-img about-img-large">
                        <img src="@Url.Content("~/images/banner/banner-property-8.jpg")">
                    </div>

                    <div class="about-img about-img-small">
                        <img src="@Url.Content("~/images/banner/banner-property-9.jpg")">
                    </div>

                </div>

            </div>

            <!-- CONTENT -->
            <div class="col-lg-6">

                <div class="section-tag">
                    ABOUT OUR COMPANY
                </div>

                <h2 class="section-title">
                    We Make Property Buying
                    Simple, Safe & Smart
                </h2>

                <p class="section-desc">
                    Our platform connects buyers, sellers, and investors
                    with the best real estate opportunities across India.
                    We focus on transparency, verified listings, and a
                    premium customer experience.
                </p>

                <div class="about-features">

                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>

                        <div>
                            <h6>Verified Listings</h6>
                            <p>Every property is carefully reviewed.</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fa-solid fa-user-shield"></i>
                        </div>

                        <div>
                            <h6>Trusted Agents</h6>
                            <p>Work with professional property experts.</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fa-solid fa-headset"></i>
                        </div>

                        <div>
                            <h6>Premium Support</h6>
                            <p>Fast and dedicated customer assistance.</p>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= WHY CHOOSE US ================= -->
<section class="why-section">

    <div class="container">

        <div class="section-header text-center">

            <div class="section-tag mx-auto">
                WHY CHOOSE US
            </div>

            <h2 class="section-title">
                Experience Modern Real Estate
            </h2>

            <p class="section-desc mx-auto">
                Everything you need to buy, sell, or rent properties
                with complete confidence.
            </p>

        </div>

        <div class="row g-4 mt-4">

            <!-- CARD -->
            <div class="col-lg-4">

                <div class="why-card">

                    <div class="why-icon blue">
                        <i class="fa-solid fa-house-circle-check"></i>
                    </div>

                    <h4>Premium Properties</h4>

                    <p>
                        Explore high-quality verified properties with
                        premium amenities and prime locations.
                    </p>

                </div>

            </div>

            <!-- CARD -->
            <div class="col-lg-4">

                <div class="why-card">

                    <div class="why-icon green">
                        <i class="fa-solid fa-user-tie"></i>
                    </div>

                    <h4>Professional Agents</h4>

                    <p>
                        Connect with trusted agents who provide
                        expert market guidance and support.
                    </p>

                </div>

            </div>

            <!-- CARD -->
            <div class="col-lg-4">

                <div class="why-card">

                    <div class="why-icon orange">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>

                    <h4>Secure Transactions</h4>

                    <p>
                        Enjoy safe and transparent property
                        transactions with complete peace of mind.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= CTA SECTION ================= -->
<section class="cta-section">

    <div class="container">

        <div class="cta-box">

            <div class="row align-items-center">

                <div class="col-lg-8">

                    <div class="section-tag light">
                        START YOUR JOURNEY
                    </div>

                    <h2>
                        Looking For Your Dream Property?
                    </h2>

                    <p>
                        Browse thousands of premium listings updated daily.
                    </p>

                </div>

                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">

                    <a asp-controller="User"
                       asp-action="Listing"
                       class="cta-btn">
                        Explore Listings
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<style>

    :root {
        --primary: #1565ff;
        --dark: #0f172a;
        --text: #64748b;
        --light: #f8fafc;
        --border: #e2e8f0;
    }

    body {
        background: #ffffff;
    }

    /* ================= HERO ================= */

    .about-hero {
        background: linear-gradient(135deg,#081028 0%,#0f172a 40%,#1565ff 100%);
        padding: 120px 0 90px;
        position: relative;
    }

    .hero-pattern {
        position: absolute;
        width: 100%;
        height: 100%;
        background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);
        background-size: 30px 30px;
        opacity: 0.4;
    }

    .min-vh-75 {
        min-height: 75vh;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,0.12);
        color: white;
        padding: 10px 18px;
        border-radius: 50px;
        backdrop-filter: blur(10px);
        font-weight: 600;
        font-size: 14px;
    }

    .hero-title {
        font-size: 64px;
        line-height: 1.1;
        font-weight: 800;
        color: white;
        margin-bottom: 24px;
    }

        .hero-title span {
            color: #7fb2ff;
        }

    .hero-desc {
        color: rgba(255,255,255,0.75);
        font-size: 18px;
        line-height: 1.8;
        margin-bottom: 35px;
        max-width: 600px;
    }

    .btn-primary-custom {
        background: white;
        color: var(--primary);
        padding: 16px 34px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: .3s;
    }

        .btn-primary-custom:hover {
            transform: translateY(-4px);
            color: var(--primary);
        }

    .btn-outline-custom {
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        padding: 16px 34px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        backdrop-filter: blur(10px);
        transition: .3s;
    }

        .btn-outline-custom:hover {
            background: white;
            color: var(--primary);
        }

    .hero-stats {
        display: flex;
        gap: 20px;
        margin-top: 60px;
        flex-wrap: wrap;
    }

    .stat-box {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 22px 28px;
        min-width: 160px;
    }

        .stat-box h3 {
            color: white;
            font-size: 34px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .stat-box p {
            color: rgba(255,255,255,0.7);
            margin: 0;
            font-size: 14px;
        }

    /* HERO IMAGES */

    .hero-images {
        position: relative;
        height: 650px;
    }

    .img-main {
        position: absolute;
        right: 0;
        top: 0;
        width: 78%;
        height: 100%;
        border-radius: 35px;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.25);
    }

    .img-small {
        position: absolute;
        width: 220px;
        height: 260px;
        border-radius: 28px;
        overflow: hidden;
        border: 8px solid white;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    .img-small-1 {
        left: 0;
        top: 70px;
    }

    .img-small-2 {
        left: 40px;
        bottom: 60px;
    }

    .hero-images img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .floating-card {
        position: absolute;
        right: -20px;
        bottom: 40px;
        background: white;
        border-radius: 22px;
        padding: 18px 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    .float-icon {
        width: 55px;
        height: 55px;
        background: rgba(21,101,255,0.1);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 22px;
    }

    .floating-card h6 {
        margin: 0;
        font-weight: 700;
    }

    .floating-card p {
        margin: 0;
        color: var(--text);
        font-size: 14px;
    }

    /* ================= COMMON ================= */

    .section-tag {
        display: inline-block;
        background: rgba(21,101,255,0.08);
        color: var(--primary);
        padding: 10px 18px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }

        .section-tag.light {
            background: rgba(255,255,255,0.15);
            color: white;
        }

    .section-title {
        font-size: 48px;
        font-weight: 800;
        line-height: 1.2;
        color: var(--dark);
        margin-bottom: 20px;
    }

    .section-desc {
        color: var(--text);
        font-size: 17px;
        line-height: 1.9;
        max-width: 650px;
    }

    /* ================= ABOUT ================= */

    .about-section {
        padding: 110px 0;
    }

    .about-image-grid {
        position: relative;
        padding-right: 80px;
    }

    .about-img {
        overflow: hidden;
        border-radius: 30px;
    }

        .about-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .about-img-large {
        height: 580px;
    }

    .about-img-small {
        width: 260px;
        height: 300px;
        position: absolute;
        right: 0;
        bottom: 40px;
        border: 10px solid white;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .about-features {
        margin-top: 40px;
    }

    .feature-item {
        display: flex;
        gap: 18px;
        margin-bottom: 28px;
    }

    .feature-icon {
        min-width: 60px;
        height: 60px;
        background: rgba(21,101,255,0.08);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 22px;
    }

    .feature-item h6 {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .feature-item p {
        color: var(--text);
        margin: 0;
    }

    /* ================= WHY ================= */

    .why-section {
        padding: 110px 0;
        background: #f8fbff;
    }

    .section-header {
        margin-bottom: 40px;
    }

    .why-card {
        background: white;
        border-radius: 28px;
        padding: 45px 35px;
        text-align: center;
        border: 1px solid #eef2f7;
        transition: .35s;
        height: 100%;
    }

        .why-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 50px rgba(15,23,42,0.08);
        }

    .why-icon {
        width: 90px;
        height: 90px;
        border-radius: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto auto 25px;
        font-size: 34px;
    }

        .why-icon.blue {
            background: rgba(21,101,255,0.1);
            color: #1565ff;
        }

        .why-icon.green {
            background: rgba(0,200,120,0.1);
            color: #00b96b;
        }

        .why-icon.orange {
            background: rgba(255,145,0,0.1);
            color: #ff9100;
        }

    .why-card h4 {
        font-weight: 800;
        margin-bottom: 16px;
    }

    .why-card p {
        color: var(--text);
        line-height: 1.8;
        margin: 0;
    }

    /* ================= CTA ================= */

    .cta-section {
        padding: 0 0 110px;
    }

    .cta-box {
        background: linear-gradient(135deg,#1565ff,#0f172a);
        border-radius: 40px;
        padding: 70px;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .cta-box::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            top: -180px;
            right: -120px;
        }

        .cta-box h2 {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .cta-box p {
            color: rgba(255,255,255,0.75);
            font-size: 18px;
            margin: 0;
        }

    .cta-btn {
        background: white;
        color: var(--primary);
        padding: 18px 40px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        display: inline-block;
        transition: .3s;
    }

        .cta-btn:hover {
            transform: translateY(-5px);
            color: var(--primary);
        }

    /* ================= RESPONSIVE ================= */

    @@media(max-width:991px) {

        .hero-title,
        .section-title,
        .cta-box h2 {
            font-size: 40px;
        }

        .hero-images {
            height: 500px;
            margin-top: 60px;
        }

        .img-small {
            width: 160px;
            height: 200px;
        }

        .about-img-small {
            width: 180px;
            height: 220px;
        }

        .cta-box {
            padding: 50px 35px;
            text-align: center;
        }
    }

    @@media(max-width:767px) {

        .hero-title,
        .section-title,
        .cta-box h2 {
            font-size: 32px;
        }

        .hero-stats {
            gap: 12px;
        }

        .stat-box {
            width: 100%;
        }

        .hero-images {
            height: 400px;
        }

        .img-small {
            display: none;
        }

        .img-main {
            width: 100%;
        }

        .floating-card {
            right: 20px;
            left: 20px;
        }

        .about-image-grid {
            padding-right: 0;
        }

        .about-img-small {
            display: none;
        }

        .about-img-large {
            height: 420px;
        }

        .section-padding {
            padding: 70px 0;
        }
    }

</style>