@model RealEstateProject.Models.Property

<h2>Add Property</h2>

<form asp-action="AddProperty" method="post">

    <div class="mb-2">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="mb-2">
        <label>Price</label>
        <input asp-for="Price" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Category</label>
        <select asp-for="CategoryId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "CategoryName"))">
        </select>
    </div>

    <div class="mb-2">
        <label>City</label>
        <select asp-for="CityId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Cities, "CityId", "CityName"))">
        </select>
    </div>

    <button class="btn btn-primary">Submit</button>

</form>