@model IEnumerable<RealEstateProject.Models.Amenity>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Amenities";
    ViewData["ActivePage"] = "Amenity";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 16px;
    }

    .page-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
        margin: 0;
    }

    .page-subtitle {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 4px 0 0 0;
    }

    .section-card {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        background: #f8fafc;
        padding: 12px 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        text-align: left;
        border-bottom: 1px solid var(--border-color);
    }

    .data-table td {
        padding: 16px 20px;
        font-size: 0.875rem;
        color: var(--text-main);
        border-bottom: 1px solid var(--border-color);
        vertical-align: middle;
    }

    .data-table tr:last-child td {
        border-bottom: none;
    }

    .data-table tr:hover td {
        background-color: #f8fafc;
    }

    .amenity-name {
        font-weight: 500;
        color: #0f172a;
    }

    .btn-action {
        background: #ffffff;
        border: 1px solid var(--border-color);
        color: #0f172a;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
    }

    .btn-action:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
    }

    .btn-primary-action {
        background: #2563eb;
        border-color: #2563eb;
        color: #ffffff;
        padding: 8px 16px;
    }

    .btn-primary-action:hover {
        background: #1d4ed8;
        border-color: #1d4ed8;
        color: #ffffff;
    }

    .btn-edit { border-color: #fcd34d; color: #d97706; }
    .btn-edit:hover { background: #fef3c7; border-color: #f59e0b; color: #b45309; }

    .btn-delete { border-color: #fca5a5; color: #dc2626; }
    .btn-delete:hover { background: #fef2f2; border-color: #ef4444; color: #b91c1c; }
</style>

<div class="container-fluid p-0">
    <div class="page-header">
        <div>
            <h1 class="page-title">Manage Amenities</h1>
            <p class="page-subtitle">Configure amenities available for properties.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn-action btn-primary-action">
                <i class="fa-solid fa-plus"></i> Add Amenity
            </a>
        </div>
    </div>

    <div class="section-card">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Amenity Name</th>
                        <th>Description</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">#@item.AmenityId</td>
                            <td><span class="amenity-name">@item.AmenityName</span></td>
                            <td class="text-muted">@item.Description</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.AmenityId" class="btn-action btn-edit">
                                        <i class="fa-solid fa-pen"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.AmenityId" class="btn-action btn-delete" onclick="return confirm('Are you sure you want to delete this amenity?');">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if(!Model.Any())
            {
                <div class="text-center py-5 text-muted" style="font-size: 0.875rem;">
                    <p class="m-0">No amenities found.</p>
                </div>
            }
        </div>
    </div>
</div>